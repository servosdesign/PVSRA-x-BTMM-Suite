bool showPsychologicalLevels = input.bool(group = 'Weekly Psycological Levels (Intraday Only)', defval = false, title = 'Show Psycological Levels', inline = 'psyconf') and showPsychologicalLevelsOnSupportedMinuteCharts
bool showPsychologicalLevelLabels = input.bool(group = 'Weekly Psycological Levels (Intraday Only)', defval = false, title = 'Show Psycological Level Labels', inline = 'psyconf', tooltip = 'The psycological High/Low will only show on these timeframes: 1h/30min/15min/5min/3min/1min. It is disabled on all others. This is because the calculation requires a candle to start at the correct time for Sydney/Tokyo but in other timeframes the data does not have values at the designated time for the Sydney/Tokyo sessions.') and showPsychologicalLevels
bool showAllHistoricalPsychologicalLevels = input.bool(group = 'Weekly Psycological Levels (Intraday Only)', defval = false, title = 'Show Historical Psycological Levels', inline = 'psyconf') and showPsychologicalLevels
color psychologicalLevelHighColor = input.color(group = 'Weekly Psycological Levels (Intraday Only)', title = 'Psycological High Color', defval = color(#ff9800), inline = 'psyconf1')
color psychologicalLevelLowColor = input.color(group = 'Weekly Psycological Levels (Intraday Only)', title = 'Psycological Low Color', defval = color(#ff9800), inline = 'psyconf1')

[psychologicalLevelHigh, psychologicalLevelLow, psychologicalHighLabelText, psychologicalLowLabelText, psychologicalSessionStartTime] =
 trLib.calcPsyLevels(
    ONE_WEEK_IN_MILLISECONDS,
    showPsychologicalLevels,
    FOREX,
    sydneyDSTActive
)

trLib.rLabelLastBar(
    psychologicalLevelHigh,
    psychologicalHighLabelText,
    label.style_none,
    psychologicalLevelHighColor,
    showPsychologicalLevelLabels,
    labelXOffset
)

trLib.rLabelLastBar(
    psychologicalLevelLow,
    psychologicalLowLabelText,
    label.style_none,
    psychologicalLevelLowColor,
    showPsychologicalLevelLabels,
    labelXOffset
)

plot(
    showPsychologicalLevelsOnSupportedMinuteCharts and
     showPsychologicalLevels and
      showAllHistoricalPsychologicalLevels ? psychologicalLevelHigh : na,
    color = psychologicalLevelHighColor,
    style = plot.style_stepline,
    linewidth = 1,
    editable = false,
    title = 'Historical Psycological High'
)

plot(
    showPsychologicalLevelsOnSupportedMinuteCharts and
     showPsychologicalLevels and
      showAllHistoricalPsychologicalLevels ? psychologicalLevelLow : na,
    color = psychologicalLevelLowColor,
    style = plot.style_stepline,
    linewidth = 1,
    editable = false,
    title = 'Historical Psycological Low'
)

f_sessionHLBox(
    bool enabled,
    string sessTime,
    color boxColor,
    color labelColor,
    string labelText,
    string tz,
    bool showHighLowLines,
    color highLowLineColor,
    string highLowLineStyle,
    bool showMidLine,
    color midLineColor,
    string midLineStyle
) =>
    var box sessionBox = na
    var label sessionLabel = na
    var label metricLabel = na
    var line sessionHighLine = na
    var line sessionMidLine = na
    var line sessionLowLine = na
    var float sessionHigh = na
    var float sessionLow = na
    var float sessionOpen = na
    var int sessionStartTime = na

    bool inSession = enabled and not na(time_close(timeframe.period, sessTime, tz))

    if inSession and not inSession[1]
        sessionHigh := high
        sessionLow := low
        sessionOpen := open
        sessionStartTime := time
        sessionBox := box.new(bar_index, high, bar_index, low, bgcolor = boxColor, border_color = boxColor)
        sessionLabel := showMarketSessionLabels ? label.new(bar_index, high, labelText, style = label.style_none, textcolor = labelColor, size = size.small, yloc = yloc.price) : na
        metricLabel := showSessionMetrics and sessionMetricsAllowedTf ? label.new(bar_index, low, '', style = label.style_label_up, textcolor = color.new(labelColor, 0), color = color.new(boxColor, 100), size = size.small, yloc = yloc.price) : na

        if showHighLowLines
            sessionHighLine := line.new(x1 = sessionStartTime, y1 = sessionHigh, x2 = dayEndTime, y2 = sessionHigh, xloc = xloc.bar_time, color = highLowLineColor, style = highLowLineStyle, width = 1)
            sessionLowLine := line.new(x1 = sessionStartTime, y1 = sessionLow, x2 = dayEndTime, y2 = sessionLow, xloc = xloc.bar_time, color = highLowLineColor, style = highLowLineStyle, width = 1)

        if showMidLine
            midY = (sessionHigh + sessionLow) / 2.0
            sessionMidLine := line.new(x1 = sessionStartTime, y1 = midY, x2 = dayEndTime, y2 = midY, xloc = xloc.bar_time, color = midLineColor, style = midLineStyle, width = 1)

    if inSession and not na(sessionBox)
        sessionHigh := math.max(sessionHigh, high)
        sessionLow := math.min(sessionLow, low)
        box.set_top(sessionBox, sessionHigh)
        box.set_bottom(sessionBox, sessionLow)
        box.set_right(sessionBox, bar_index)
        sessionRange = sessionHigh - sessionLow
        sessionMove = close - sessionOpen
        percent = sessionOpen != 0 ? sessionRange / sessionOpen * 100 : na
        forexPipSize = str.contains(syminfo.ticker, JPY_TICKER) ? 0.01 : 0.0001
        rangeCount = syminfo.type == FOREX ? sessionRange / forexPipSize : sessionRange / syminfo.mintick
        rangeUnit = syminfo.type == FOREX ? PIPS : TICKS

        metricText = sessionMetricType == RANGE_METRIC ? str.tostring(rangeCount, '#.##') + ' ' + rangeUnit :
         sessionMetricType == CURRENCY_METRIC ? f_formatCurrency(sessionRange) :
          str.tostring(percent, '#.##') + '%'

        midX = math.round((box.get_left(sessionBox) + box.get_right(sessionBox)) / 2.0)
        topOffset = math.max(sessionRange * 0.02, syminfo.mintick * 8)
        bottomOffset = 0

        if not na(sessionLabel)
            label.set_x(sessionLabel, midX)
            label.set_y(sessionLabel, sessionHigh + topOffset)
            label.set_textalign(sessionLabel, text.align_center)
            label.set_size(sessionLabel, size.normal)

        if not na(metricLabel)
            label.set_text(metricLabel, metricText)
            label.set_x(metricLabel, midX)
            label.set_y(metricLabel, sessionLow - bottomOffset)
            label.set_textalign(metricLabel, text.align_center)
            label.set_size(metricLabel, size.normal)

        if not na(sessionHighLine)
            line.set_xy1(sessionHighLine, sessionStartTime, sessionHigh)
            line.set_xy2(sessionHighLine, dayEndTime, sessionHigh)

        if not na(sessionLowLine)
            line.set_xy1(sessionLowLine, sessionStartTime, sessionLow)
            line.set_xy2(sessionLowLine, dayEndTime, sessionLow)

        if not na(sessionMidLine)
            midY = (sessionHigh + sessionLow) / 2.0
            line.set_xy1(sessionMidLine, sessionStartTime, midY)
            line.set_xy2(sessionMidLine, dayEndTime, midY)

    if not inSession and inSession[1]
        sessionHigh := na
        sessionLow := na
        sessionOpen := na

if barstate.islast
    if showDailyOpenLine and isIntradayTimeframe and not showHistoricalDailyOpenLines
        dailyOpenLine := f_upsertLine(dailyOpenLine, dayStartTime, dailyOpenPrice, dayEndTime, dailyOpenPrice, dailyOpenColor, dailyOpenLineStyle, dailyOpenLineExtend)
        if showDailyOpenLabel
            dailyOpenLabel := f_upsertLabel(dailyOpenLabel, dayEndTime, dailyOpenPrice, DAILY_OPEN_LABEL, dailyOpenColor)
        else
            if not na(dailyOpenLabel)
                label.delete(dailyOpenLabel)
                dailyOpenLabel := na
    else
        if not na(dailyOpenLine)
            line.delete(dailyOpenLine)
            dailyOpenLine := na
        if not na(dailyOpenLabel)
            label.delete(dailyOpenLabel)
            dailyOpenLabel := na

    if isIntradayTimeframe and showPreviousDayHighLow
        previousDayHighLine := f_upsertLine(previousDayHighLine, dayStartTime, previousDayHigh, dayEndTime, previousDayHigh, previousDayHighLowColor, previousDayHighLowStyle, previousDayLineExtend)
        previousDayLowLine := f_upsertLine(previousDayLowLine, dayStartTime, previousDayLow, dayEndTime, previousDayLow, previousDayHighLowColor, previousDayHighLowStyle, previousDayLineExtend)
    else
        if not na(previousDayHighLine)
            line.delete(previousDayHighLine)
            previousDayHighLine := na
        if not na(previousDayLowLine)
            line.delete(previousDayLowLine)
            previousDayLowLine := na

    if isIntradayTimeframe and showPreviousDayHighLow and showPreviousDayHighLowLabels
        previousDayHighLabel := f_upsertLabel(previousDayHighLabel, dayEndTime, previousDayHigh, PDH_LABEL, previousDayHighLowColor)
        previousDayLowLabel := f_upsertLabel(previousDayLowLabel, dayEndTime, previousDayLow, PDL_LABEL, previousDayHighLowColor)
    else
        if not na(previousDayHighLabel)
            label.delete(previousDayHighLabel)
            previousDayHighLabel := na
        if not na(previousDayLowLabel)
            label.delete(previousDayLowLabel)
            previousDayLowLabel := na

    if isIntradayOrDailyTimeframe and showPreviousWeekHighLow
        if na(previousWeekHighLine)
            previousWeekHighLine := line.new(x1 = dayStartTime, y1 = previousWeekHigh, x2 = dayEndTime, y2 = previousWeekHigh, xloc = xloc.bar_time, extend = previousWeekLineExtend, color = previousWeekHighLowColor, style = previousWeekHighLowStyle, width = 1)
            previousWeekHighLine
        else
            line.set_xy1(previousWeekHighLine, dayStartTime, previousWeekHigh)
            line.set_xy2(previousWeekHighLine, dayEndTime, previousWeekHigh)
            line.set_color(previousWeekHighLine, previousWeekHighLowColor)
            line.set_style(previousWeekHighLine, previousWeekHighLowStyle)
            line.set_width(previousWeekHighLine, 1)
            line.set_extend(previousWeekHighLine, previousWeekLineExtend)
            line.set_extend(previousWeekLowLine, previousWeekLineExtend)

        if na(previousWeekLowLine)
            previousWeekLowLine := line.new(x1 = dayStartTime, y1 = previousWeekLow, x2 = dayEndTime, y2 = previousWeekLow, xloc = xloc.bar_time, extend = previousWeekLineExtend, color = previousWeekHighLowColor, style = previousWeekHighLowStyle, width = 1)
            previousWeekLowLine
        else
            line.set_xy1(previousWeekLowLine, dayStartTime, previousWeekLow)
            line.set_xy2(previousWeekLowLine, dayEndTime, previousWeekLow)
            line.set_color(previousWeekLowLine, previousWeekHighLowColor)
            line.set_style(previousWeekLowLine, previousWeekHighLowStyle)
            line.set_width(previousWeekLowLine, 1)
            line.set_extend(previousWeekHighLine, previousWeekLineExtend)
            line.set_extend(previousWeekLowLine, previousWeekLineExtend)
    else
        if not na(previousWeekHighLine)
            line.delete(previousWeekHighLine)
            previousWeekHighLine := na
            previousWeekHighLine
        if not na(previousWeekLowLine)
            line.delete(previousWeekLowLine)
            previousWeekLowLine := na
            previousWeekLowLine

    if isIntradayOrDailyTimeframe and showPreviousWeekHighLow and showPreviousDayHighLowLabels
        if na(previousWeekHighLabel)
            previousWeekHighLabel := label.new(x = dayEndTime, y = previousWeekHigh, text = PWH_LABEL, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_up, textcolor = previousWeekHighLowColor, color = color.new(color.black, 100), size = size.small)
            previousWeekHighLabel
        else
            label.set_x(previousWeekHighLabel, dayEndTime)
            label.set_y(previousWeekHighLabel, previousWeekHigh)
            label.set_text(previousWeekHighLabel, PWH_LABEL)
            label.set_textcolor(previousWeekHighLabel, previousWeekHighLowColor)
            label.set_style(previousWeekHighLabel, label.style_label_up)
            label.set_color(previousWeekHighLabel, color.new(color.black, 100))
            label.set_size(previousWeekHighLabel, size.small)

        if na(previousWeekLowLabel)
            previousWeekLowLabel := label.new(x = dayEndTime, y = previousWeekLow, text = PWL_LABEL, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_up, textcolor = previousWeekHighLowColor, color = color.new(color.black, 100), size = size.small)
            previousWeekLowLabel
        else
            label.set_x(previousWeekLowLabel, dayEndTime)
            label.set_y(previousWeekLowLabel, previousWeekLow)
            label.set_text(previousWeekLowLabel, PWL_LABEL)
            label.set_textcolor(previousWeekLowLabel, previousWeekHighLowColor)
            label.set_style(previousWeekLowLabel, label.style_label_up)
            label.set_color(previousWeekLowLabel, color.new(color.black, 100))
            label.set_size(previousWeekLowLabel, size.small)
    else
        if not na(previousWeekHighLabel)
            label.delete(previousWeekHighLabel)
            previousWeekHighLabel := na
            previousWeekHighLabel
        if not na(previousWeekLowLabel)
            label.delete(previousWeekLowLabel)
            previousWeekLowLabel := na
            previousWeekLowLabel

    if showADR and isIntradayTimeframe
        adrHighLine := f_upsertLine(adrHighLine, dayStartTime, dailyADRHighLevel, dayEndTime, dailyADRHighLevel, adrColor, adrStyle, adrLineExtend)
        adrLowLine := f_upsertLine(adrLowLine, dayStartTime, dailyADRLowLevel, dayEndTime, dailyADRLowLevel, adrColor, adrStyle, adrLineExtend)
    else
        if not na(adrHighLine)
            line.delete(adrHighLine)
            adrHighLine := na
        if not na(adrLowLine)
            line.delete(adrLowLine)
            adrLowLine := na

    if showADR and showADR50 and isIntradayTimeframe
        adr50HighLine := f_upsertLine(adr50HighLine, dayStartTime, dailyADR50HighLevel, dayEndTime, dailyADR50HighLevel, adrColor, adrStyle, adrLineExtend)
        adr50LowLine := f_upsertLine(adr50LowLine, dayStartTime, dailyADR50LowLevel, dayEndTime, dailyADR50LowLevel, adrColor, adrStyle, adrLineExtend)
    else
        if not na(adr50HighLine)
            line.delete(adr50HighLine)
            adr50HighLine := na
        if not na(adr50LowLine)
            line.delete(adr50LowLine)
            adr50LowLine := na

    if showADR and isIntradayTimeframe and showADRLabels
        adrHighLabel := f_upsertLabel(adrHighLabel, dayEndTime, dailyADRHighLevel, ADR_HIGH_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), adrColor)
        adrLowLabel := f_upsertLabel(adrLowLabel, dayEndTime, dailyADRLowLevel, ADR_LOW_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), adrColor)
    else
        if not na(adrHighLabel)
            label.delete(adrHighLabel)
            adrHighLabel := na
        if not na(adrLowLabel)
            label.delete(adrLowLabel)
            adrLowLabel := na

    if showADR and showADR50 and isIntradayTimeframe and showADRLabels
        adr50HighLabel := f_upsertLabel(adr50HighLabel, dayEndTime, dailyADR50HighLevel, ADR_50_HIGH_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), adrColor)
        adr50LowLabel := f_upsertLabel(adr50LowLabel, dayEndTime, dailyADR50LowLevel, ADR_50_LOW_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), adrColor)
    else
        if not na(adr50HighLabel)
            label.delete(adr50HighLabel)
            adr50HighLabel := na
        if not na(adr50LowLabel)
            label.delete(adr50LowLabel)
            adr50LowLabel := na

    if showADR and isIntradayTimeframe and showADRLabels and showADRMetrics
        adrRangeOffset = showADR50 ? math.max(syminfo.mintick * 20, dailyADRValue * 0.02) : 0.0
        adrMid = (dailyADRHighLevel + dailyADRLowLevel) / 2 + adrRangeOffset
        adrText = ADR_RANGE_PREFIX + f_formatRangeMetric(dailyADRValue, adrMetricDisplayMode) + '\n' + ADR_3X_PREFIX + f_formatRangeMetric(dailyADRValue * 3, adrMetricDisplayMode)
        adrRangeLabel := f_upsertLabel(adrRangeLabel, dayEndTime, adrMid, adrText, adrColor)
    else
        if not na(adrRangeLabel)
            label.delete(adrRangeLabel)
            adrRangeLabel := na

    if showADR and showADR50 and isIntradayTimeframe and showADRLabels and showADRMetrics
        adrRangeOffset50 = math.max(syminfo.mintick * 10, dailyADRValue * 0.02)
        adrMid50 = (dailyADR50HighLevel + dailyADR50LowLevel) / 2 - adrRangeOffset50
        adrText50 = ADR_50_RANGE_PREFIX + f_formatRangeMetric(dailyADRValue / 2, adrMetricDisplayMode)
        adr50RangeLabel := f_upsertLabel(adr50RangeLabel, dayEndTime, adrMid50, adrText50, adrColor)
    else
        if not na(adr50RangeLabel)
            label.delete(adr50RangeLabel)
            adr50RangeLabel := na

    if showAWR and isIntradayTimeframe
        awrHighLine := f_upsertLine(awrHighLine, dayStartTime, weeklyAWRHighLevel, dayEndTime, weeklyAWRHighLevel, awrColor, awrStyle, awrLineExtend)
        awrLowLine := f_upsertLine(awrLowLine, dayStartTime, weeklyAWRLowLevel, dayEndTime, weeklyAWRLowLevel, awrColor, awrStyle, awrLineExtend)
    else
        if not na(awrHighLine)
            line.delete(awrHighLine)
            awrHighLine := na
        if not na(awrLowLine)
            line.delete(awrLowLine)
            awrLowLine := na

    if showAWR and showAWR50 and isIntradayTimeframe
        awr50HighLine := f_upsertLine(awr50HighLine, dayStartTime, weeklyAWR50HighLevel, dayEndTime, weeklyAWR50HighLevel, awrColor, awrStyle, awrLineExtend)
        awr50LowLine := f_upsertLine(awr50LowLine, dayStartTime, weeklyAWR50LowLevel, dayEndTime, weeklyAWR50LowLevel, awrColor, awrStyle, awrLineExtend)
    else
        if not na(awr50HighLine)
            line.delete(awr50HighLine)
            awr50HighLine := na
        if not na(awr50LowLine)
            line.delete(awr50LowLine)
            awr50LowLine := na

    if showAWR and isIntradayTimeframe and showAWRLabels
        awrHighLabel := f_upsertLabel(awrHighLabel, dayEndTime, weeklyAWRHighLevel, AWR_HIGH_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
        awrLowLabel := f_upsertLabel(awrLowLabel, dayEndTime, weeklyAWRLowLevel, AWR_LOW_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
    else
        if not na(awrHighLabel)
            label.delete(awrHighLabel)
            awrHighLabel := na
        if not na(awrLowLabel)
            label.delete(awrLowLabel)
            awrLowLabel := na

    if showAWR and showAWR50 and isIntradayTimeframe and showAWRLabels
        awr50HighLabel := f_upsertLabel(awr50HighLabel, dayEndTime, weeklyAWR50HighLevel, AWR_50_HIGH_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
        awrLow50Label := f_upsertLabel(awrLow50Label, dayEndTime, weeklyAWR50LowLevel, AWR_50_LOW_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
    else
        if not na(awr50HighLabel)
            label.delete(awr50HighLabel)
            awr50HighLabel := na
        if not na(awrLow50Label)
            label.delete(awrLow50Label)
            awrLow50Label := na

    if showAWR and isIntradayTimeframe and showAWRLabels and showAWRMetrics
        awrRangeOffset = showAWR50 ? math.max(syminfo.mintick * 20, weeklyAWRValue * 0.02) : 0.0
        awrMid = (weeklyAWRHighLevel + weeklyAWRLowLevel) / 2 + awrRangeOffset
        awrText = AWR_RANGE_PREFIX + f_formatRangeMetric(weeklyAWRValue, awrMetricDisplayMode) + '\n' + AWR_3X_PREFIX + f_formatRangeMetric(weeklyAWRValue * 3, awrMetricDisplayMode)
        awrRangeLabel := f_upsertLabel(awrRangeLabel, dayEndTime, awrMid, awrText, awrColor)
    else
        if not na(awrRangeLabel)
            label.delete(awrRangeLabel)
            awrRangeLabel := na

    if showAWR and showAWR50 and isIntradayTimeframe and showAWRLabels and showAWRMetrics
        awrRangeOffset50 = math.max(syminfo.mintick * 10, weeklyAWRValue * 0.02)
        awrMid50 = (weeklyAWR50HighLevel + weeklyAWR50LowLevel) / 2 - awrRangeOffset50
        awrText50 = AWR_50_RANGE_PREFIX + f_formatRangeMetric(weeklyAWRValue / 2, awrMetricDisplayMode)
        awr50RangeLabel := f_upsertLabel(awr50RangeLabel, dayEndTime, awrMid50, awrText50, awrColor)
    else
        if not na(awr50RangeLabel)
            label.delete(awr50RangeLabel)
            awr50RangeLabel := na

    if showAMR and isIntradayTimeframe and isMinuteChart and timeframe.multiplier >= 3
        amrHighLine := f_upsertLine(amrHighLine, dayStartTime, monthlyAMRHighLevel, dayEndTime, monthlyAMRHighLevel, amrColor, amrStyle, amrLineExtend)
        amrLowLine := f_upsertLine(amrLowLine, dayStartTime, monthlyAMRLowLevel, dayEndTime, monthlyAMRLowLevel, amrColor, amrStyle, amrLineExtend)
    else
        if not na(amrHighLine)
            line.delete(amrHighLine)
            amrHighLine := na
        if not na(amrLowLine)
            line.delete(amrLowLine)
            amrLowLine := na

    if showAMR and showAMR50 and isIntradayTimeframe and isMinuteChart and timeframe.multiplier >= 3
        amr50HighLine := f_upsertLine(amr50HighLine, dayStartTime, monthlyAMR50HighLevel, dayEndTime, monthlyAMR50HighLevel, amrColor, amrStyle, amrLineExtend)
        amr50LowLine := f_upsertLine(amr50LowLine, dayStartTime, monthlyAMR50LowLevel, dayEndTime, monthlyAMR50LowLevel, amrColor, amrStyle, amrLineExtend)
    else
        if not na(amr50HighLine)
            line.delete(amr50HighLine)
            amr50HighLine := na
        if not na(amr50LowLine)
            line.delete(amr50LowLine)
            amr50LowLine := na

    if showAMR and isIntradayTimeframe and showAMRLabels and isMinuteChart and timeframe.multiplier >= 3
        amrHighLabel := f_upsertLabel(amrHighLabel, dayEndTime, monthlyAMRHighLevel, AMR_HIGH_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
        amrLowLabel := f_upsertLabel(amrLowLabel, dayEndTime, monthlyAMRLowLevel, AMR_LOW_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
    else
        if not na(amrHighLabel)
            label.delete(amrHighLabel)
            amrHighLabel := na
        if not na(amrLowLabel)
            label.delete(amrLowLabel)
            amrLowLabel := na

    if showAMR and showAMR50 and isIntradayTimeframe and showAMRLabels and isMinuteChart and timeframe.multiplier >= 3
        amr50HighLabel := f_upsertLabel(amr50HighLabel, dayEndTime, monthlyAMR50HighLevel, AMR_50_HIGH_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
        amr50LowLabel := f_upsertLabel(amr50LowLabel, dayEndTime, monthlyAMR50LowLevel, AMR_50_LOW_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
    else
        if not na(amr50HighLabel)
            label.delete(amr50HighLabel)
            amr50HighLabel := na
        if not na(amr50LowLabel)
            label.delete(amr50LowLabel)
            amr50LowLabel := na

    if showAMR and isIntradayTimeframe and showAMRLabels and showAMRMetrics and isMinuteChart and timeframe.multiplier >= 3
        amrRangeOffset = showAMR50 ? math.max(syminfo.mintick * 20, monthlyAMRValue * 0.02) : 0.0
        amrMid = (monthlyAMRHighLevel + monthlyAMRLowLevel) / 2 + amrRangeOffset
        amrText = AMR_RANGE_PREFIX + f_formatRangeMetric(monthlyAMRValue, amrMetricDisplayMode) + '\n' + AMR_3X_PREFIX + f_formatRangeMetric(monthlyAMRValue * 3, amrMetricDisplayMode)
        amrRangeLabel := f_upsertLabel(amrRangeLabel, dayEndTime, amrMid, amrText, amrColor)
    else
        if not na(amrRangeLabel)
            label.delete(amrRangeLabel)
            amrRangeLabel := na

    if showAMR and showAMR50 and isIntradayTimeframe and showAMRLabels and showAMRMetrics and isMinuteChart and timeframe.multiplier >= 3
        amrRangeOffset50 = math.max(syminfo.mintick * 10, monthlyAMRValue * 0.02)
        amrMid50 = (monthlyAMR50HighLevel + monthlyAMR50LowLevel) / 2 - amrRangeOffset50
        amrText50 = AMR_50_RANGE_PREFIX + f_formatRangeMetric(monthlyAMRValue / 2, amrMetricDisplayMode)
        amr50RangeLabel := f_upsertLabel(amr50RangeLabel, dayEndTime, amrMid50, amrText50, amrColor)
    else
        if not na(amr50RangeLabel)
            label.delete(amr50RangeLabel)
            amr50RangeLabel := na

f_sessionHLBox(
    showAsiaSession,
    asianSessionTime,
    asianSessionBoxColor,
    asianSessionTextColor,
    asianSessionLabelText,
    NEW_YORK_TIMEZONE,
    showAsianSessionHighLowLines,
    asianSessionHighLowLineColor,
    asianSessionHighLowLineStyle,
    showAsianSessionMidLine,
    asianSessionMidLineColor,
    asianSessionMidLineStyle
    )

f_sessionHLBox(
    showEuBrinksSession,
    euBrinksSessionTime,
    euBrinksSessionBoxColor,
    euBrinksSessionTextColor,
    euBrinksSessionLabelText,
    LONDON_TIMEZONE,
    false,
    euBrinksSessionTextColor,
    DASHED_LINE_STYLE,
