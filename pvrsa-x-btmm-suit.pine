f_sessionHLBox(
    showUsBrinksSession,
    usBrinksSessionTime,
    usBrinksSessionBoxColor,
    usBrinksSessionTextColor,
    usBrinksSessionLabelText,
    NEW_YORK_TIMEZONE,
    false,
    usBrinksSessionTextColor,
    DASHED_LINE_STYLE,
    false,
    usBrinksSessionTextColor,
    DASHED_LINE_STYLE
)

f_sessionHLBox(
    showNewYorkSession,
    newYorkSessionTime,
    newYorkSessionBoxColor,
    newYorkSessionTextColor,
    newYorkSessionLabelText,
    NEW_YORK_TIMEZONE,
    false,
    newYorkSessionTextColor,
    DASHED_LINE_STYLE,
    false,
    newYorkSessionTextColor,
    DASHED_LINE_STYLE
)

if barstate.islast and not showAllHistoricalPsychologicalLevels and showPsychologicalLevels
    psychologicalHighLine := f_upsertHorizontalLine(
        psychologicalHighLine,
        psychologicalSessionStartTime,
        psychologicalLevelHigh,
        psychologicalLevelHighColor
    )

    psychologicalLowLine := f_upsertHorizontalLine(
        psychologicalLowLine,
        psychologicalSessionStartTime,
        psychologicalLevelLow,
        psychologicalLevelLowColor
    )
