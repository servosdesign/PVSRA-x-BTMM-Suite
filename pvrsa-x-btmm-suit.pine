const string WEEKLY_OPEN_SUFFIX = '(WO)'
const string MONTHLY_OPEN_SUFFIX = '(MO)'

var int currentSessionStart = na
var int currentSessionEnd = na
var line dailyOpenLine = na
var line previousDayHighLine = na
var line previousDayLowLine = na
var line previousWeekHighLine = na
var line previousWeekLowLine = na
var line adrHighLine = na
var line adrLowLine = na
