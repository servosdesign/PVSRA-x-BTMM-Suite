const string PDH_LABEL = 'PDH'
const string PDL_LABEL = 'PDL'
const string PWH_LABEL = 'PWH'
const string PWL_LABEL = 'PWL'
const string ADR_HIGH_LABEL = 'ADR High'
const string ADR_LOW_LABEL = 'ADR Low'
