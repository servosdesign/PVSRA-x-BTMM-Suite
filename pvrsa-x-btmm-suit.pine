var label adr50LowLabel = na
var label adrRangeLabel = na
var label adr50RangeLabel = na
var label awrHighLabel = na
var label awrLowLabel = na
var label awr50HighLabel = na
var label awrLow50Label = na
var label awrRangeLabel = na
var label awr50RangeLabel = na
var label amrHighLabel = na
var label amrLowLabel = na
var label amr50HighLabel = na
var label amr50LowLabel = na
var label amrRangeLabel = na
var label amr50RangeLabel = na

int labelXOffset = time_close * timeframe.multiplier * 60 * 1000
int dayStartTime = time(DAILY_TIMEFRAME)
int dayEndTime = time_close(DAILY_TIMEFRAME)
int separatorReferenceTime = last_bar_time
int regularTradingHoursSessionStart = time(timeframe.period, REGULAR_TRADING_HOURS_SESSION, NEW_YORK_TIMEZONE)
int pivotAndMLabelsXOffset = time_close * timeframe.multiplier * 60 * 1000
float ema5 = ta.ema(close, EMA_5_LENGTH)
float ema13 = ta.ema(close, EMA_13_LENGTH)
float ema50 = ta.ema(close, EMA_50_LENGTH)
float ema200 = ta.ema(close, EMA_200_LENGTH)
float ema800 = ta.ema(close, EMA_800_LENGTH)
float dailyOpenPrice = trLib.getdayOpen()
float visibleLabelBase = ta.highest(high, 300)
float dayLabelY = visibleLabelBase + math.max(ta.atr(14) * 0.25, syminfo.mintick * 20)
bool isMinuteChart = timeframe.isminutes
bool isSecondsChart = timeframe.isseconds
bool useCurrentDayStart = isSecondsChart or (isMinuteChart and timeframe.multiplier < 5)
bool isIntradayVisibleTimeframe = isMinuteChart and timeframe.multiplier <= 240 and timeframe.multiplier >= 1
bool isIntradayTimeframe = timeframe.isintraday
bool isIntradayOrDailyTimeframe = isIntradayTimeframe or timeframe.isdaily
bool isNewDay = ta.change(dayStartTime) != 0
bool isNewWeek = ta.change(time('W')) != 0
bool inRegularTradingHours = not na(time(timeframe.period, REGULAR_TRADING_HOURS_SESSION, NEW_YORK_TIMEZONE))
bool isNewRegularTradingHoursSession = inRegularTradingHours and not inRegularTradingHours[1]

int pivotAndMLevelsStart = useCurrentDayStart ? dayStartTime :
 dayStartTime - 86400 * 1000

if isNewDay
    currentSessionStart := na
    currentSessionEnd := na

if isNewRegularTradingHoursSession
    currentSessionStart := regularTradingHoursSessionStart
    currentSessionEnd := timestamp(
        NEW_YORK_TIMEZONE,
        year(regularTradingHoursSessionStart, NEW_YORK_TIMEZONE),
        month(regularTradingHoursSessionStart, NEW_YORK_TIMEZONE),
        dayofmonth(regularTradingHoursSessionStart,NEW_YORK_TIMEZONE), 16, 0
    )

int currentDayMidpoint = not na(currentSessionStart) and not na(currentSessionEnd) ?
 math.round((currentSessionStart + currentSessionEnd) / 2) :
  math.round((dayStartTime + dayEndTime) / 2)

int sessionDay = dayofweek(currentDayMidpoint, NEW_YORK_TIMEZONE)

string currencySymbol = syminfo.currency == 'USD' ? '$' :
     syminfo.currency == 'EUR' ? '€' :
     syminfo.currency == 'GBP' ? '£' : ''

f_securityWithRepaintControl(string _symbol, string _res, series float _src, bool _repaint) =>
    request.security(_symbol, _res, _src[_repaint ? 0 :
     barstate.isrealtime ? 1 : 0])[_repaint ? 0 :
     barstate.isrealtime ? 0 : 1]

float dayClose = f_securityWithRepaintControl(syminfo.tickerid, DAILY_TIMEFRAME, close, false)
float previousDayHigh = f_securityWithRepaintControl(syminfo.tickerid, DAILY_TIMEFRAME, high, false)
float previousDayLow = f_securityWithRepaintControl(syminfo.tickerid, DAILY_TIMEFRAME, low, false)
float previousWeekHigh = f_securityWithRepaintControl(syminfo.tickerid, 'W', high, false)
float previousWeekLow = f_securityWithRepaintControl(syminfo.tickerid, 'W', low, false)

float pivotPoint = (previousDayHigh + previousDayLow + dayClose) / 3
float pivotResistanceLevel1 = 2 * pivotPoint - previousDayLow
float pivotSupportLevel1 = 2 * pivotPoint - previousDayHigh
float pivotResistanceLevel2 = pivotPoint - pivotSupportLevel1 + pivotResistanceLevel1
float pivotSupportLevel2 = pivotPoint - pivotResistanceLevel1 + pivotSupportLevel1
float pivotResistanceLevel3 = 2 * pivotPoint + previousDayHigh - 2 * previousDayLow
float pivotSupportLevel3 = 2 * pivotPoint - (2 * previousDayHigh - previousDayLow)
float mLevel0 = (pivotSupportLevel2 + pivotSupportLevel3) / 2
float mLevel1 = (pivotSupportLevel1 + pivotSupportLevel2) / 2
float mLevel2 = (pivotPoint + pivotSupportLevel1) / 2
float mLevel3 = (pivotPoint + pivotResistanceLevel1) / 2
float mLevel4 = (pivotResistanceLevel1 + pivotResistanceLevel2) / 2
float mLevel5 = (pivotResistanceLevel2 + pivotResistanceLevel3) / 2

f_extendSession(string session) =>
    startHour = str.tonumber(str.substring(session, 0, 2))
    startMinute = str.tonumber(str.substring(session, 2, 4))
    endHour = str.tonumber(str.substring(session, 5, 7))
    endMinute = str.tonumber(str.substring(session, 7, 9))
    timeframeMinute = isMinuteChart ? timeframe.multiplier : 1
    newEndMinute = endMinute + timeframeMinute
    newEndHour = endHour + math.floor(newEndMinute / 60)
    newEndMinute := newEndMinute % 60

    str.format('{0,number,00}{1,number,00}-{2,number,00}{3,number,00}',
        startHour, startMinute, newEndHour, newEndMinute)

f_formatCurrency(float currency) =>
    currencySymbol != '' ? currencySymbol + str.tostring(currency, format.mintick) :
     str.tostring(currency, format.mintick) + ' ' + syminfo.currency

f_formatRangeMetric(float rangeMetric, string displayMode) =>
    float forexPipSize = str.contains(syminfo.ticker, JPY_TICKER) ? 0.01 : 0.0001
    float rangeCount = syminfo.type == FOREX ? rangeMetric / forexPipSize : rangeMetric / syminfo.mintick
    string rangeUnit = syminfo.type == FOREX ? PIPS : TICKS
    float percent = close != 0 ? rangeMetric / close * 100 : na

    displayMode == RANGE_METRIC ? str.tostring(rangeCount, '#.##') + ' ' + rangeUnit :
     displayMode == CURRENCY_METRIC ? f_formatCurrency(rangeMetric) :
     str.tostring(percent, '#.##') + '%'

f_pvsraVolume(string tickerId) =>
    request.security(tickerId, '', [volume, high, low, close, open], barmerge.gaps_off, barmerge.lookahead_off)

[pvsraVolume, pvsraHigh, pvsraLow, pvsraClose, pvsraOpen] = f_pvsraVolume(syminfo.tickerid)

f_dayName(int day) =>
    day == dayofweek.monday ? 'Mon' :
     day == dayofweek.tuesday ? 'Tue' :
     day == dayofweek.wednesday ? 'Wed' :
     day == dayofweek.thursday ? 'Thu' :
     day == dayofweek.friday ? 'Fri' :
     day == dayofweek.saturday ? 'Sat' : 'Sun'

string dayLabelText = na(sessionDay) ? '' : f_dayName(sessionDay)

f_upsertHorizontalLine(line existingLine, int startTime, float price, color lineColor) =>
    line resultLine = existingLine

    if na(resultLine)
        resultLine := line.new(
            x1 = startTime,
            y1 = price,
            x2 = time,
            y2 = price,
            xloc = xloc.bar_time,
            extend = extend.none,
            color = lineColor
        )
    else
        line.set_xy1(resultLine, startTime, price)
        line.set_xy2(resultLine, time, price)

    resultLine

f_resolveLineStyle(simple string lineStyle) =>
    lineStyle == DOTTED ? DOTTED_LINE_STYLE :
     lineStyle == SOLID ? SOLID_LINE_STYLE :
      DASHED_LINE_STYLE

f_upsertLine(line existingLine, int x1, float y1, int x2, float y2, color lineColor, simple string lineStyle, simple string lineExtend) =>
    line result = existingLine
    if na(result)
        result := line.new(x1 = x1, y1 = y1, x2 = x2, y2 = y2, xloc = xloc.bar_time, extend = lineExtend, color = lineColor, style = lineStyle)

    else
        line.set_xy1(result, x1, y1)
        line.set_xy2(result, x2, y2)
        line.set_color(result, lineColor)
        line.set_style(result, lineStyle)
        line.set_width(result, 1)
        line.set_extend(result, lineExtend)
    result

f_upsertLabel(label existingLabel, int x, float y, string labelText, color textColor) =>
    label result = existingLabel
    if na(result)
        result := label.new(x = x, y = y, text = labelText, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_up, textcolor = textColor, color = color.new(color.black, 100), size = size.small)

    else
        label.set_x(result, x)
        label.set_y(result, y)
        label.set_text(result, labelText)
        label.set_textcolor(result, textColor)
        label.set_style(result, label.style_label_up)
        label.set_color(result, color.new(color.black, 100))
        label.set_size(result, size.small)
    result

bool scaleHelpMessage = input.bool(true, 'Scale Help', group = 'Chart Scaling', tooltip = 'If levels like PWH/PWL, ADR, AWR, or AMR compress the chart, right-click the price scale on the right and enable "Scale price chart only".')

color vectorRedCandleColor = input.color(title = 'Vector: Red', group = 'Candle Colors', defval = #FF5252, inline = 'vectorCandles', tooltip = 'Bull bars are green and bear bars are red when the bar is with volume >= 200% of the average volume of the 10 previous bars, or bars where the product of candle spread x candle volume is >= the highest for the 10 previous bars.\nBull bars are blue and bear bars are violet when the bar is with volume >= 150% of the average volume of the 10 previous bars.')
color vectorGreenCandleColor = input.color(title = 'Vector: Green', group = 'Candle Colors', defval = #00E676, inline = 'vectorCandles')
color vectorVioletCandleColor = input.color(title = 'Vector: Violet', group = 'Candle Colors', defval = #E040FB, inline = 'vectorCandles')
color vectorBlueCandleColor = input.color(title = 'Vector: Blue', group = 'Candle Colors', defval = #2962ff, inline = 'vectorCandles')
color nonVectorUpCandleColor = input.color(title = 'Non-Vector: Up', group = 'Candle Colors', defval = #999999, inline = 'nonVectorCandles')
color nonVectorDownCandleColor = input.color(title = 'Non-Vector: Down', group = 'Candle Colors', defval = #4d4d4d, inline = 'nonVectorCandles', tooltip = 'Bull bars are light gray and bear bars are dark gray when none of the red/green/blue/violet vector conditions are met.')

[pvsraColor, alertFlag, averageVolume, volumeSpread, highestVolumeSpread] = trLib.calcPvsra(
    pvsraVolume,
    pvsraHigh,
    pvsraLow,
    pvsraClose,
    pvsraOpen,
    vectorRedCandleColor,
    vectorGreenCandleColor,
    vectorVioletCandleColor,
    vectorBlueCandleColor,
    nonVectorDownCandleColor,
    nonVectorUpCandleColor
)

barcolor(pvsraColor)
[newYorkDSTActive, londonDSTActive, sydneyDSTActive] = trLib.calcDst()


bool showEma5 = input.bool(group = 'EMA Lines', title = '5', defval = true, inline = 'emaToggles')
bool showEma13 = input.bool(group = 'EMA Lines', title = '13', defval = true, inline = 'emaToggles')
bool showEma50 = input.bool(group = 'EMA Lines', title = '50', defval = true, inline = 'emaToggles')
bool showEma200 = input.bool(group = 'EMA Lines', title = '200', defval = true, inline = 'emaToggles')
bool showEma800 = input.bool(group = 'EMA Lines', title = '800', defval = true, inline = 'emaToggles')
color ema5Color = input.color(group = 'EMA Lines', title = '5', defval = color(#feea4a), inline = 'emaColors')
color ema13Color = input.color(group = 'EMA Lines', title = '13', defval = color(#fd5457), inline = 'emaColors')
color ema50Color = input.color(group = 'EMA Lines', title = '50', defval = color(#3ee145), inline = 'emaColors')
color ema200Color = input.color(group = 'EMA Lines', title = '200', defval = color(#7c6db0), inline = 'emaColors')
color ema800Color = input.color(group = 'EMA Lines', title = '800', defval = color(color.rgb(155, 198, 248)), inline = 'emaColors')

if showEma5
    trLib.rLabel(ema5, EMA_5_LABEL, label.style_none, ema5Color, false, labelXOffset)
if showEma13
    trLib.rLabel(ema13, EMA_13_LABEL, label.style_none, ema13Color, false, labelXOffset)
if showEma50
    trLib.rLabel(ema50, EMA_50_LABEL, label.style_none, ema50Color, false, labelXOffset)
if showEma200
    trLib.rLabel(ema200, EMA_200_LABEL, label.style_none, ema200Color, false, labelXOffset)
if showEma800
    trLib.rLabel(ema800, EMA_800_LABEL, label.style_none, ema800Color, false, labelXOffset)

plot(showEma5 ? ema5 : na, color = ema5Color, title = EMA_5_LABEL)
plot(showEma13 ? ema13 : na, color = ema13Color, title = EMA_13_LABEL)
plot(showEma50 ? ema50 : na, color = ema50Color, title = EMA_50_LABEL)
plot(showEma200 ? ema200 : na, color = ema200Color, title = EMA_200_LABEL)
plot(showEma800 ? ema800 : na, color = ema800Color, title = EMA_800_LABEL)

bool showDailyOpenLine = input.bool(group = 'Daily Open (Intraday Only)', defval = true, title = 'Show Line', inline = 'dopenconf') and isMinuteChart
bool showDailyOpenLabel = input.bool(group = 'Daily Open (Intraday Only)', defval = true, title = 'Show Label', inline = 'dopenconf') and showDailyOpenLine and isMinuteChart
bool showHistoricalDailyOpenLines = input.bool(group = 'Daily Open (Intraday Only)', defval = false, title = 'Show Historical Daily Opens', inline = 'dopenconf')
color dailyOpenColor = input.color(group = 'Daily Open (Intraday Only)', title = 'Daily Open Color', defval = color.new(#ba6d99, 50), inline = 'dopenconf1')
string dailyOpenLineStyleX = input.string(group = 'Daily Open (Intraday Only)', defval = DOTTED, title = 'Daily Open Line Style', options = [DOTTED, DASHED, SOLID], inline = 'dopenconf1')
string dailyOpenLineStyle = f_resolveLineStyle(dailyOpenLineStyleX)
bool extendDailyOpenLine = input.bool(group = 'Daily Open (Intraday Only)', title = 'Extend Line in Both Directions', defval = false, inline = 'dopenconf2')
string dailyOpenLineExtend = extendDailyOpenLine ? extend.both : extend.none
float dailyOpenPlotValue = showDailyOpenLine and showHistoricalDailyOpenLines ? dailyOpenPrice : na

plot(
    dailyOpenPlotValue,
    color = dailyOpenColor,
    style = plot.style_stepline,
    linewidth = 1,
    editable = false,
    title = 'Historical Daily Open'
)

bool showPreviousDayHighLow = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Show PDH/PDL Lines', defval = true, inline = 'highlow', tooltip = 'PDH/PDL show only on intraday timeframes, whereas PWH/PWL show up to the daily timeframe.')
color previousDayHighLowColor = input.color(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Daily Color', defval = color.new(color.blue, 50), inline = 'highlow2')
string previousDayHighLowStyleX = input.string(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Daily Style', defval = DASHED, options = [DOTTED, DASHED, SOLID], inline = 'highlow2')
string previousDayHighLowStyle = f_resolveLineStyle(previousDayHighLowStyleX)
bool showPreviousWeekHighLow = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Show PWH/PWL Lines', defval = true, inline = 'highlow')
color previousWeekHighLowColor = input.color(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Weekly Color', defval = color.new(color.green, 50), inline = 'highlow3')
string previousWeekHighLowStyleX = input.string(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Weekly Style', defval = DASHED, options = [DOTTED, DASHED, SOLID], inline = 'highlow3')
string previousWeekHighLowStyle = f_resolveLineStyle(previousWeekHighLowStyleX)
bool showPreviousDayHighLowLabels = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Show Labels', defval = true, inline = 'highlow')
bool extendPreviousDayLines  = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Extend PDH/PDL Lines in Both Directions', defval = false, inline = 'highlow4')
bool extendPreviousWeekLines  = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Extend PWH/PWL Lines in Both Directions', defval = false, inline = 'highlow5')
string previousDayLineExtend = extendPreviousDayLines ? extend.both : extend.none
string previousWeekLineExtend = extendPreviousWeekLines ? extend.both : extend.none

bool showDaySeparators = input.bool(true, 'Show Day Separators', group = 'Time Separators')
bool showDaySeparatorLabels = input.bool(true, 'Show Day Labels', group = 'Time Separators')
color daySeparatorColor = input.color(color.new(color.gray, 70), 'Day Line Color', group = 'Time Separators', inline = 'daysep')
string daySeparatorStyleInput = input.string(DASHED, 'Day Line Style', options = [DOTTED, DASHED, SOLID], group = 'Time Separators', inline = 'daysep')
int  daySeparatorWidth = input.int(1, 'Day Line Width', minval = 1, maxval = 5, group = 'Time Separators', inline = 'daysep')
bool showWeekSeparators = input.bool(true, 'Show Week Separators', group = 'Time Separators')
color weekSeparatorColor = input.color(color.new(color.blue, 60), 'Week Line Color', group = 'Time Separators', inline = 'weeksep')
string weekSeparatorStyleInput = input.string(DASHED, 'Week Line Style', options = [DOTTED, DASHED, SOLID], group = 'Time Separators', inline = 'weeksep')
int weekSeparatorWidth = input.int(2, 'Week Line Width', minval = 1, maxval = 5, group = 'Time Separators', inline = 'weeksep')
color dayLabelColor = input.color(color.gray, 'Day Label Color', group = 'Time Separators')
int separatorLookbackWeeks = input.int(3, 'Lookback (weeks)', minval = 1, maxval = 52, group = 'Time Separators')
int maxSeparatorLineTimeframeInMinutes = input.int(240, 'Hide Separator Lines Above Timeframe (min)', minval = 1, maxval = 1439, group = 'Time Separators')
int maxSeparatorLabelTimeframeInMinutes = input.int(60, 'Hide Day Labels Above Timeframe (min)', minval = 1, maxval = 1439, group = 'Time Separators')
string daySeparatorStyle = f_resolveLineStyle(daySeparatorStyleInput)
string weekSeparatorStyle = f_resolveLineStyle(weekSeparatorStyleInput)
int lookbackStartTime = separatorReferenceTime - separatorLookbackWeeks * ONE_WEEK_IN_MILLISECONDS
bool isInLookbackWindow = time >= lookbackStartTime

bool separatorLinesAllowedTf = isSecondsChart ? true :
 isMinuteChart ? timeframe.multiplier <= maxSeparatorLineTimeframeInMinutes :
  false

bool separatorLabelsAllowedTf = isSecondsChart ? true :
 isMinuteChart ? timeframe.multiplier <= maxSeparatorLabelTimeframeInMinutes :
  false

bool showDaySeparatorLinesNow = timeframe.isintraday and isInLookbackWindow and separatorLinesAllowedTf and showDaySeparators
bool showWeekSeparatorLinesNow = timeframe.isintraday and isInLookbackWindow and separatorLinesAllowedTf and showWeekSeparators
bool showDayLabelsNow = timeframe.isintraday and isInLookbackWindow and separatorLabelsAllowedTf and showDaySeparatorLabels

var array<line> daySeparatorLinesArray = array.new<line>()
var array<line> weekSeparatorLinesArray = array.new<line>()
var array<label> daySeparatorLabelsArray = array.new<label>()

if not showDaySeparatorLinesNow
    if array.size(daySeparatorLinesArray) > 0
        for i = 0 to array.size(daySeparatorLinesArray) - 1 by 1
            line.delete(array.get(daySeparatorLinesArray, i))
        array.clear(daySeparatorLinesArray)

if not showWeekSeparatorLinesNow
    if array.size(weekSeparatorLinesArray) > 0
        for i = 0 to array.size(weekSeparatorLinesArray) - 1 by 1
            line.delete(array.get(weekSeparatorLinesArray, i))
        array.clear(weekSeparatorLinesArray)

if not showDayLabelsNow
    if array.size(daySeparatorLabelsArray) > 0
        for i = 0 to array.size(daySeparatorLabelsArray) - 1 by 1
            label.delete(array.get(daySeparatorLabelsArray, i))
        array.clear(daySeparatorLabelsArray)

if showDayLabelsNow and isNewDay
    newDayLabel = label.new(
         currentDayMidpoint,
         dayLabelY,
         dayLabelText,
         xloc = xloc.bar_time,
         yloc = yloc.price,
         style = label.style_none,
         size = size.small,
         textcolor = dayLabelColor)
    array.push(daySeparatorLabelsArray, newDayLabel)

if showDaySeparatorLinesNow and isNewDay and not isNewWeek
    newDayLine = line.new(
         time, low, time, high,
         xloc = xloc.bar_time,
         extend = extend.both,
         color = daySeparatorColor,
         style = daySeparatorStyle,
         width = daySeparatorWidth)
    array.push(daySeparatorLinesArray, newDayLine)

if showWeekSeparatorLinesNow and isNewWeek
    line.new(
         time, low, time, high,
         xloc = xloc.bar_time,
         extend = extend.both,
         color = weekSeparatorColor,
         style = weekSeparatorStyle,
         width = weekSeparatorWidth)

if barstate.islast
    if array.size(daySeparatorLabelsArray) > 0
        for i = 0 to array.size(daySeparatorLabelsArray) - 1 by 1
            existingDayLabel = array.get(daySeparatorLabelsArray, i)
            label.set_y(existingDayLabel, dayLabelY)

bool showADR = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Show ADR Line', defval = true, inline = 'adr')
bool showDailyOpenADR = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Use Daily Open for ADR Calculation', defval = false, inline = 'adr', tooltip = 'Measure the ADR from the daily open. This will make the ADR static throughout the day. ADR is usually measured taking today High / Low. Since todays High / Low will change throughout the day, some might prefer to have a static range instead.')
bool showADRLabels = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Show ADR Labels', defval = true, inline = 'adr1')
bool showADR50 = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Show 50% ADR Lines and Labels', defval = false, inline = 'adr1')
string adrMetricDisplayMode = input.string(RANGE_METRIC, 'ADR Range Metrics', options = ['Off', RANGE_METRIC, CURRENCY_METRIC, 'Percent'], group = 'Average Daily Range - ADR (intraday only)', inline = 'adr1')
int adrRange = input.int(group = 'Average Daily Range - ADR (intraday only)', title = 'ADR Length (days)', defval = 14, minval = 1, maxval = 31, step = 1, inline = 'adr2', tooltip = 'Defaults taken from MT4. This defines how many days back to take into consideration when calculating the ADR')
color adrColor = input.color(group = 'Average Daily Range - ADR (intraday only)', title = 'ADR Color', defval = color(#5f9ea0), inline = 'adr3')
string adrStyleX = input.string(group = 'Average Daily Range - ADR (intraday only)', defval = SOLID, title = 'ADR Line Style', options = [DOTTED, DASHED, SOLID], inline = 'adr3')
bool extendADRLines = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Extend ADR Lines in Both Directions', defval = false, inline = 'adr4')
string adrLineExtend = extendADRLines ? extend.both : extend.none
string adrStyle = f_resolveLineStyle(adrStyleX)

[dailyADRValue, dailyADRHighLevel, dailyADRLowLevel] =
 request.security(
    syminfo.tickerid,
    DAILY_TIMEFRAME,
    trLib.adrHiLo(adrRange, 1, showDailyOpenADR),
    lookahead = barmerge.lookahead_on
)

float dailyADR50HighLevel = dailyADRHighLevel - dailyADRValue / 2
float dailyADR50LowLevel = dailyADRLowLevel + dailyADRValue / 2
bool showADRMetrics = adrMetricDisplayMode != 'Off'

bool showAWR = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Show AWR Line', defval = false, inline = 'awr')
bool showWeeklyOpenAWR = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Use Weekly Open for AWR Calculation', defval = false, inline = 'awr', tooltip = 'Measure the AWR from the weekly open. This will make the AWR static throughout the week. AWR is usually measured taking this weeks High / Low. Since this weeks High / Low will change throughout the week, some might prefer to have a static range instead.')
bool showAWRLabels = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Show AWR Labels', defval = false, inline = 'awr1')
bool showAWR50 = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Show 50% AWR Lines and Labels', defval = false, inline = 'awr1')
string awrMetricDisplayMode = input.string(RANGE_METRIC, 'AWR Range Metrics', options = ['Off', RANGE_METRIC, CURRENCY_METRIC, 'Percent'], group = 'Average Weekly Range - AWR (intraday only)', inline = 'awr1')
int awrRange = input.int(group = 'Average Weekly Range - AWR (intraday only)', title = 'AWR length (weeks)', defval = 4, minval = 1, maxval = 52, step = 1, inline = 'awr2', tooltip = 'Defaults taken from MT4. This defines how many weeks back to take into consideration when calculating the AWR')
color awrColor = input.color(group = 'Average Weekly Range - AWR (intraday only)', title = 'AWR Color', defval = color.rgb(84, 123, 130), inline = 'awr3')
string awrStyleX = input.string(group = 'Average Weekly Range - AWR (intraday only)', defval = SOLID, title = 'AWR Line Style', options = [DOTTED, DASHED, SOLID], inline = 'awr3')
bool extendAWRLines  = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Extend AWR Lines in Both Directions', defval = false, inline = 'awr4')
string awrLineExtend = extendAWRLines ? extend.both : extend.none

string awrStyle = f_resolveLineStyle(awrStyleX)

[weeklyAWRValue, weeklyAWRHighLevel, weeklyAWRLowLevel] =
 request.security(
