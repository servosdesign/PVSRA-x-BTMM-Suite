//@version=6
indicator(title = 'PVSRA × BTMM Suite', shorttitle = 'PVRSAxBTMM', overlay = true, scale = scale.none, max_bars_back = 300, max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)
import TradersReality/Traders_Reality_Lib/2 as trLib

const int EMA_5_LENGTH = 5
const int EMA_13_LENGTH = 13
const int EMA_50_LENGTH = 50
const int EMA_200_LENGTH = 200
const int EMA_800_LENGTH = 800
const int ONE_WEEK_IN_MILLISECONDS = 7 * 24 * 60 * 60 * 1000
const string EMA_5_LABEL = '5 EMA'
const string EMA_13_LABEL = '13 EMA'
const string EMA_50_LABEL = '50 EMA'
const string EMA_200_LABEL = '200 EMA'
const string EMA_800_LABEL = '800 EMA'
const string FOREX = 'forex'
const string PIPS = 'pips'
const string TICKS = 'ticks'
const string RANGE_METRIC = 'Range'
const string CURRENCY_METRIC = 'Currency'
const string JPY_TICKER = 'JPY'
const string REGULAR_TRADING_HOURS_SESSION = '0930-1600'
const string NEW_YORK_TIMEZONE = 'America/New_York'
const string LONDON_TIMEZONE = 'Europe/London'
const string ASIA_SESSION_DEFAULT = '1700-0100'
const string EU_BRINKS_SESSION_DEFAULT = '0800-0900'
const string LONDON_SESSION_DEFAULT = '0800-1700'
const string US_BRINKS_SESSION_DEFAULT = '0900-1000'
