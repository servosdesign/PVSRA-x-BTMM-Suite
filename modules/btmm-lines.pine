//@version=6
indicator(title = 'PVSRA x BTMM Horizontal Lines', shorttitle = 'BTMM H-Lines', overlay = true, max_bars_back = 300, max_lines_count = 500, max_labels_count = 500, dynamic_requests = true, behind_chart = false)

const int MAX_HISTORICAL_DAILY_OPEN_DAYS = 200
const int MAX_HISTORICAL_PSYCHOLOGICAL_WEEKS = 100
const string FOREX = 'forex'
const string CRYPTO = 'crypto'
const string PIPS = 'pips'
const string TICKS = 'ticks'
const string RANGE_METRIC = 'Range'
const string CURRENCY_METRIC = 'Currency'
const string JPY_TICKER = 'JPY'
const string NEW_YORK_TIMEZONE = 'America/New_York'
const string ASIA_SESSION_DEFAULT = '1700-0100'
const string DOTTED = 'Dotted'
const string DASHED = 'Dashed'
const string SOLID = 'Solid'
const string DASHED_LINE_STYLE = line.style_dashed
const string DOTTED_LINE_STYLE = line.style_dotted
const string SOLID_LINE_STYLE = line.style_solid
const string ALL_DAYS_SESSION_SUFFIX = ':1234567'
const string DAILY_TIMEFRAME = 'D'
const string PIVOT_TAG = 'Pivot'
const string PIVOT_RESISTANCE_1_TAG = 'R1'
const string PIVOT_RESISTANCE_2_TAG = 'R2'
const string PIVOT_RESISTANCE_3_TAG = 'R3'
const string PIVOT_SUPPORT_1_TAG = 'S1'
const string PIVOT_SUPPORT_2_TAG = 'S2'
const string PIVOT_SUPPORT_3_TAG = 'S3'
const string M_LEVEL_0_TAG = 'M0'
const string M_LEVEL_1_TAG = 'M1'
const string M_LEVEL_2_TAG = 'M2'
const string M_LEVEL_3_TAG = 'M3'
const string M_LEVEL_4_TAG = 'M4'
const string M_LEVEL_5_TAG = 'M5'
const string PSYCHOLOGICAL_HIGH_LABEL = 'Psy High'
const string PSYCHOLOGICAL_LOW_LABEL = 'Psy Low'
const string DAILY_OPEN_LABEL = 'Open'
const string PDH_LABEL = 'PDH'
const string PDL_LABEL = 'PDL'
const string PWH_LABEL = 'PWH'
const string PWL_LABEL = 'PWL'
const string ADR_HIGH_LABEL = 'ADR High'
const string ADR_LOW_LABEL = 'ADR Low'
const string ADR_50_HIGH_LABEL = '50% ADR High'
const string ADR_50_LOW_LABEL = '50% ADR Low'
const string ADR_RANGE_PREFIX = 'ADR = '
const string ADR_3X_PREFIX = '3 x ADR = '
const string ADR_50_RANGE_PREFIX = '50% ADR = '
const string AWR_HIGH_LABEL = 'AWR High'
const string AWR_LOW_LABEL = 'AWR Low'
const string AWR_50_HIGH_LABEL = '50% AWR High'
const string AWR_50_LOW_LABEL = '50% AWR Low'
const string AWR_RANGE_PREFIX = 'AWR = '
const string AWR_3X_PREFIX = '3 x AWR = '
const string AWR_50_RANGE_PREFIX = '50% AWR = '
const string AMR_HIGH_LABEL = 'Hi-AMR'
const string AMR_LOW_LABEL = 'Lo-AMR'
const string AMR_50_HIGH_LABEL = '50% Hi-AMR'
const string AMR_50_LOW_LABEL = '50% Lo-AMR'
const string AMR_RANGE_PREFIX = 'AMR = '
const string AMR_3X_PREFIX = '3 x AMR = '
const string AMR_50_RANGE_PREFIX = '50% AMR = '
const string DAILY_OPEN_SUFFIX = '(DO)'
const string WEEKLY_OPEN_SUFFIX = '(WO)'
const string MONTHLY_OPEN_SUFFIX = '(MO)'

var float currentDayHigh = na
var float currentDayLow = na
var line dailyOpenLine = na
var line previousDayHighLine = na
var line previousDayLowLine = na
var line previousWeekHighLine = na
var line previousWeekLowLine = na
var line adrHighLine = na
var line adrLowLine = na
var line adr50HighLine = na
var line adr50LowLine = na
var line awrHighLine = na
var line awrLowLine = na
var line awr50HighLine = na
var line awr50LowLine = na
var line amrHighLine = na
var line amrLowLine = na
var line amr50HighLine = na
var line amr50LowLine = na
var line psychologicalHighLine = na
var line psychologicalLowLine = na
var line pivotPointLine = na
var line pivotResistanceLevel1Line = na
var line pivotSupportLevel1Line = na
var line pivotResistanceLevel2Line = na
var line pivotSupportLevel2Line = na
var line pivotResistanceLevel3Line = na
var line pivotSupportLevel3Line = na
var line mLevel0Line = na
var line mLevel1Line = na
var line mLevel2Line = na
var line mLevel3Line = na
var line mLevel4Line = na
var line mLevel5Line = na
var float weeklyPsychologicalSessionHigh = na
var float weeklyPsychologicalSessionLow = na
var int weeklyPsychologicalSessionStartTime = na
var float confirmedPsychologicalSessionHigh = na
var float confirmedPsychologicalSessionLow = na
var line activeHistoricalPsychologicalHighLine = na
var line activeHistoricalPsychologicalLowLine = na
var label dailyOpenLabel = na
var label previousDayHighLabel = na
var label previousDayLowLabel = na
var label previousWeekHighLabel = na
var label previousWeekLowLabel = na
var label adrHighLabel = na
var label adrLowLabel = na
var label adr50HighLabel = na
var label adr50LowLabel = na
var label adrRangeLabel = na
var label adr50RangeLabel = na
var label awrHighLabel = na
var label awrLowLabel = na
var label awr50HighLabel = na
var label awrLow50Label = na
var label awrRangeLabel = na
var label awr50RangeLabel = na
var label amrHighLabel = na
var label amrLowLabel = na
var label amr50HighLabel = na
var label amr50LowLabel = na
var label amrRangeLabel = na
var label amr50RangeLabel = na
var label psychologicalHighLabel = na
var label psychologicalLowLabel = na
var label pivotPointLabel = na
var label pivotResistanceLevel1Label = na
var label pivotSupportLevel1Label = na
var label pivotResistanceLevel2Label = na
var label pivotSupportLevel2Label = na
var label pivotResistanceLevel3Label = na
var label pivotSupportLevel3Label = na
var label mLevel0Label = na
var label mLevel1Label = na
var label mLevel2Label = na
var label mLevel3Label = na
var label mLevel4Label = na
var label mLevel5Label = na
var array<line> historicalDailyOpenLinesArray = array.new<line>()
var int lastHistoricalDailyOpenStartTime = na
var array<line> historicalPsychologicalHighLinesArray = array.new<line>()
var array<line> historicalPsychologicalLowLinesArray = array.new<line>()

int requestedDayStartTime = request.security(syminfo.tickerid, DAILY_TIMEFRAME, time, lookahead = barmerge.lookahead_on)
int requestedDayEndTime = request.security(syminfo.tickerid, DAILY_TIMEFRAME, time_close, lookahead = barmerge.lookahead_on)
int dayStartTime = na(requestedDayStartTime) ? time(DAILY_TIMEFRAME) : requestedDayStartTime
int dayEndTime = na(requestedDayEndTime) ? time_close(DAILY_TIMEFRAME) : requestedDayEndTime
int securitySourceOffset = barstate.isrealtime ? 1 : 0
int securityResultOffset = barstate.isrealtime ? 0 : 1
int psychologicalSessionStartTime = na
float psychologicalLevelHigh = na
float psychologicalLevelLow = na
string psychologicalHighLabelText = ''
string psychologicalLowLabelText = ''
bool isMinuteChart = timeframe.isminutes
bool isIntradayTimeframe = timeframe.isintraday
bool isIntradayOrDailyTimeframe = isIntradayTimeframe or timeframe.isdaily
bool isCrypto = syminfo.type == CRYPTO
bool isNewDay = ta.change(dayStartTime) != 0

if isNewDay or na(currentDayHigh) or na(currentDayLow)
    currentDayHigh := high
    currentDayLow := low
else
    currentDayHigh := math.max(currentDayHigh, high)
    currentDayLow := math.min(currentDayLow, low)

string currencySymbol = syminfo.currency == 'USD' ? '$' :
     syminfo.currency == 'EUR' ? 'EUR ' :
     syminfo.currency == 'GBP' ? 'GBP ' : ''

[dayCloseRaw, previousDayHighRaw, previousDayLowRaw] =
 request.security(
    syminfo.tickerid,
    DAILY_TIMEFRAME,
    [close[securitySourceOffset], high[securitySourceOffset], low[securitySourceOffset]]
)

[previousWeekHighRaw, previousWeekLowRaw] =
 request.security(
    syminfo.tickerid,
    'W',
    [high[securitySourceOffset], low[securitySourceOffset]]
)

float dayClose = dayCloseRaw[securityResultOffset]
float previousDayHigh = previousDayHighRaw[securityResultOffset]
float previousDayLow = previousDayLowRaw[securityResultOffset]
float previousWeekHigh = previousWeekHighRaw[securityResultOffset]
float previousWeekLow = previousWeekLowRaw[securityResultOffset]
float pivotPoint = (previousDayHigh + previousDayLow + dayClose) / 3
float pivotResistanceLevel1 = 2 * pivotPoint - previousDayLow
float pivotSupportLevel1 = 2 * pivotPoint - previousDayHigh
float pivotResistanceLevel2 = pivotPoint - pivotSupportLevel1 + pivotResistanceLevel1
float pivotSupportLevel2 = pivotPoint - pivotResistanceLevel1 + pivotSupportLevel1
float pivotResistanceLevel3 = 2 * pivotPoint + previousDayHigh - 2 * previousDayLow
float pivotSupportLevel3 = 2 * pivotPoint - (2 * previousDayHigh - previousDayLow)
float mLevel0 = (pivotSupportLevel2 + pivotSupportLevel3) / 2
float mLevel1 = (pivotSupportLevel1 + pivotSupportLevel2) / 2
float mLevel2 = (pivotPoint + pivotSupportLevel1) / 2
float mLevel3 = (pivotPoint + pivotResistanceLevel1) / 2
float mLevel4 = (pivotResistanceLevel1 + pivotResistanceLevel2) / 2
float mLevel5 = (pivotResistanceLevel2 + pivotResistanceLevel3) / 2

f_formatCurrency(float currency) =>
    currencySymbol != '' ? currencySymbol + str.tostring(currency, format.mintick) :
     str.tostring(currency, format.mintick) + ' ' + syminfo.currency

f_formatRangeMetric(float rangeMetric, string displayMode) =>
    float forexPipSize = str.contains(syminfo.ticker, JPY_TICKER) ? 0.01 : 0.0001
    float rangeCount = syminfo.type == FOREX ? rangeMetric / forexPipSize : rangeMetric / syminfo.mintick
    string rangeUnit = syminfo.type == FOREX ? PIPS : TICKS
    float percent = close != 0 ? rangeMetric / close * 100 : na

    displayMode == RANGE_METRIC ? str.tostring(rangeCount, '#.##') + ' ' + rangeUnit :
     displayMode == CURRENCY_METRIC ? f_formatCurrency(rangeMetric) :
     str.tostring(percent, '#.##') + '%'

f_resolveLineStyle(simple string lineStyle) =>
    lineStyle == DOTTED ? DOTTED_LINE_STYLE :
     lineStyle == SOLID ? SOLID_LINE_STYLE :
      DASHED_LINE_STYLE

f_upsertLine(line existingLine, int x1, float y1, int x2, float y2, color lineColor, simple string lineStyle, simple string lineExtend) =>
    line result = existingLine
    if na(result)
        result := line.new(x1 = x1, y1 = y1, x2 = x2, y2 = y2, xloc = xloc.bar_time, extend = lineExtend, color = lineColor, style = lineStyle)

    else
        line.set_xy1(result, x1, y1)
        line.set_xy2(result, x2, y2)
        line.set_color(result, lineColor)
        line.set_style(result, lineStyle)
        line.set_width(result, 1)
        line.set_extend(result, lineExtend)
    result

f_upsertLabel(label existingLabel, int x, float y, string labelText, color textColor) =>
    label result = existingLabel
    if na(result)
        result := label.new(x = x, y = y, text = labelText, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_up, textcolor = textColor, color = color.new(color.black, 100), size = size.small)

    else
        label.set_x(result, x)
        label.set_y(result, y)
        label.set_text(result, labelText)
        label.set_textcolor(result, textColor)
        label.set_style(result, label.style_label_up)
        label.set_color(result, color.new(color.black, 100))
        label.set_size(result, size.small)
    result

f_deleteLine(line existingLine) =>
    line result = existingLine
    if not na(result)
        line.delete(result)
    result := na
    result

f_deleteLabel(label existingLabel) =>
    label result = existingLabel
    if not na(result)
        label.delete(result)
    result := na
    result

f_trackLine(array<line> linesArray, line newLine, int maxLines) =>
    array.push(linesArray, newLine)
    if array.size(linesArray) > maxLines
        line.delete(array.shift(linesArray))
    newLine

f_deleteLineArray(array<line> linesArray) =>
    if array.size(linesArray) > 0
        for i = 0 to array.size(linesArray) - 1 by 1
            line.delete(array.get(linesArray, i))
        array.clear(linesArray)

f_upsertOptionalLabel(label existingLabel, bool enabled, int x, float y, string labelText, color textColor) =>
    label result = existingLabel
    if enabled
        result := f_upsertLabel(result, x, y, labelText, textColor)
    else
        result := f_deleteLabel(result)
    result

f_calcRangeLevels(simple int length, simple int barsBack, bool fromOpen) =>
    float rangeValue = ta.sma(high - low, length)[barsBack]
    float highLevel = fromOpen ? open + rangeValue : low + rangeValue
    float lowLevel = fromOpen ? open - rangeValue : high - rangeValue

    [rangeValue, highLevel, lowLevel]

f_requestRangeLevels(bool enabled, simple string resolution, simple int length, bool fromOpen) =>
    float rangeValue = na
    float highLevel = na
    float lowLevel = na

    if enabled
        [requestedRangeValue, requestedHighLevel, requestedLowLevel] =
         request.security(
            syminfo.tickerid,
            resolution,
            f_calcRangeLevels(length, 1, fromOpen),
            lookahead = barmerge.lookahead_on
        )

        rangeValue := requestedRangeValue
        highLevel := requestedHighLevel
        lowLevel := requestedLowLevel

    [rangeValue, highLevel, lowLevel]

bool scaleHelpMessage = input.bool(true, 'Scale Help', group = 'Chart Scaling', tooltip = 'If levels like PWH/PWL, ADR, AWR, or AMR compress the chart, right-click the price scale on the right and enable "Scale price chart only".')

bool showDailyOpenLine = input.bool(group = 'Daily Open (Intraday Only)', defval = true, title = 'Show Line', inline = 'dopenconf') and isMinuteChart
bool showDailyOpenLabel = input.bool(group = 'Daily Open (Intraday Only)', defval = true, title = 'Show Label', inline = 'dopenconf') and showDailyOpenLine and isMinuteChart
bool showHistoricalDailyOpenLines = input.bool(group = 'Daily Open (Intraday Only)', defval = false, title = 'Show Historical Daily Opens', inline = 'dopenconf')
color dailyOpenColor = input.color(group = 'Daily Open (Intraday Only)', title = 'Daily Open Color', defval = color.new(#ba6d99, 50), inline = 'dopenconf1')
string dailyOpenLineStyleX = input.string(group = 'Daily Open (Intraday Only)', defval = DASHED, title = 'Daily Open Line Style', options = [DOTTED, DASHED, SOLID], inline = 'dopenconf1')
string dailyOpenLineStyle = f_resolveLineStyle(dailyOpenLineStyleX)
bool extendDailyOpenLine = input.bool(group = 'Daily Open (Intraday Only)', title = 'Extend Line in Both Directions', defval = false, inline = 'dopenconf2')
string dailyOpenLineExtend = extendDailyOpenLine ? extend.both : extend.none
float dailyOpenPrice = showDailyOpenLine ? request.security(syminfo.tickerid, DAILY_TIMEFRAME, open, lookahead = barmerge.lookahead_on) : na
bool showHistoricalDailyOpenLinesNow = showDailyOpenLine and showHistoricalDailyOpenLines and isIntradayTimeframe

bool showPreviousDayHighLow = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Show PDH/PDL Lines', defval = true, inline = 'highlow', tooltip = 'PDH/PDL show only on intraday timeframes, whereas PWH/PWL show up to the daily timeframe.')
color previousDayHighLowColor = input.color(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Daily Color', defval = color.new(color.blue, 50), inline = 'highlow2')
string previousDayHighLowStyleX = input.string(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Daily Style', defval = DASHED, options = [DOTTED, DASHED, SOLID], inline = 'highlow2')
string previousDayHighLowStyle = f_resolveLineStyle(previousDayHighLowStyleX)
bool showPreviousWeekHighLow = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Show PWH/PWL Lines', defval = true, inline = 'highlow')
color previousWeekHighLowColor = input.color(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Weekly Color', defval = color.new(color.green, 50), inline = 'highlow3')
string previousWeekHighLowStyleX = input.string(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Weekly Style', defval = DASHED, options = [DOTTED, DASHED, SOLID], inline = 'highlow3')
string previousWeekHighLowStyle = f_resolveLineStyle(previousWeekHighLowStyleX)
bool showPreviousDayHighLowLabels = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Show Labels', defval = true, inline = 'highlow')
bool extendPreviousDayLines = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Extend PDH/PDL Lines in Both Directions', defval = false, inline = 'highlow4')
bool extendPreviousWeekLines = input.bool(group = 'Previous Day\'s High / Low (PDH / PDL) and Previous Week\'s High / Low (PWH / PWL)', title = 'Extend PWH/PWL Lines in Both Directions', defval = false, inline = 'highlow5')
string previousDayLineExtend = extendPreviousDayLines ? extend.both : extend.none
string previousWeekLineExtend = extendPreviousWeekLines ? extend.both : extend.none

if not showHistoricalDailyOpenLinesNow
    f_deleteLineArray(historicalDailyOpenLinesArray)
    lastHistoricalDailyOpenStartTime := na

if showHistoricalDailyOpenLinesNow and not na(dayStartTime) and not na(dayEndTime) and not na(dailyOpenPrice)
    if na(lastHistoricalDailyOpenStartTime) or dayStartTime != lastHistoricalDailyOpenStartTime
        f_trackLine(
             historicalDailyOpenLinesArray,
             line.new(x1 = dayStartTime, y1 = dailyOpenPrice, x2 = dayEndTime, y2 = dailyOpenPrice, xloc = xloc.bar_time, extend = dailyOpenLineExtend, color = dailyOpenColor, style = dailyOpenLineStyle, width = 1),
             MAX_HISTORICAL_DAILY_OPEN_DAYS)
        lastHistoricalDailyOpenStartTime := dayStartTime
    else if array.size(historicalDailyOpenLinesArray) > 0
        currentHistoricalDailyOpenLine = array.get(historicalDailyOpenLinesArray, array.size(historicalDailyOpenLinesArray) - 1)
        line.set_xy1(currentHistoricalDailyOpenLine, dayStartTime, dailyOpenPrice)
        line.set_xy2(currentHistoricalDailyOpenLine, dayEndTime, dailyOpenPrice)
        line.set_color(currentHistoricalDailyOpenLine, dailyOpenColor)
        line.set_style(currentHistoricalDailyOpenLine, dailyOpenLineStyle)
        line.set_width(currentHistoricalDailyOpenLine, 1)
        line.set_extend(currentHistoricalDailyOpenLine, dailyOpenLineExtend)

bool showADR = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Show ADR Line', defval = true, inline = 'adr')
bool showDailyOpenADR = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Use Daily Open for ADR Calculation', defval = false, inline = 'adr', tooltip = 'Measure the ADR from the daily open. This will make the ADR static throughout the day. ADR is usually measured taking today High / Low. Since todays High / Low will change throughout the day, some might prefer to have a static range instead.')
bool showADRLabels = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Show ADR Labels', defval = true, inline = 'adr1')
bool showADR50 = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Show 50% ADR Lines and Labels', defval = false, inline = 'adr1')
string adrMetricDisplayMode = input.string(RANGE_METRIC, 'ADR Range Metrics', options = ['Off', RANGE_METRIC, CURRENCY_METRIC, 'Percent'], group = 'Average Daily Range - ADR (intraday only)', inline = 'adr1')
int adrRange = input.int(group = 'Average Daily Range - ADR (intraday only)', title = 'ADR Length (days)', defval = 14, minval = 1, maxval = 31, step = 1, inline = 'adr2', tooltip = 'Defaults taken from MT4. This defines how many days back to take into consideration when calculating the ADR')
color adrColor = input.color(group = 'Average Daily Range - ADR (intraday only)', title = 'ADR Color', defval = color(#5f9ea0), inline = 'adr3')
string adrStyleX = input.string(group = 'Average Daily Range - ADR (intraday only)', defval = SOLID, title = 'ADR Line Style', options = [DOTTED, DASHED, SOLID], inline = 'adr3')
bool extendADRLines = input.bool(group = 'Average Daily Range - ADR (intraday only)', title = 'Extend ADR Lines in Both Directions', defval = false, inline = 'adr4')
string adrLineExtend = extendADRLines ? extend.both : extend.none
string adrStyle = f_resolveLineStyle(adrStyleX)
bool calculateADR = showADR and isIntradayTimeframe

[dailyADRValue, dailyADRHighLevel, dailyADRLowLevel] =
 f_requestRangeLevels(
    calculateADR,
    DAILY_TIMEFRAME,
    adrRange,
    showDailyOpenADR
)

float dailyADR50HighLevel = dailyADRHighLevel - dailyADRValue / 2
float dailyADR50LowLevel = dailyADRLowLevel + dailyADRValue / 2
bool showADRMetrics = adrMetricDisplayMode != 'Off'
var bool dailyADRHit = false
bool dailyADRHighHit = calculateADR and not na(dailyADRHighLevel) and not na(currentDayHigh) and currentDayHigh >= dailyADRHighLevel
bool dailyADRLowHit = calculateADR and not na(dailyADRLowLevel) and not na(currentDayLow) and currentDayLow <= dailyADRLowLevel
bool dailyADRHitNow = dailyADRHighHit or dailyADRLowHit
if isNewDay or not calculateADR
    dailyADRHit := false
if dailyADRHitNow
    dailyADRHit := true
color activeADRColor = dailyADRHit ? color.red : adrColor
int activeADRLineWidth = dailyADRHit ? 2 : 1

bool showAWR = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Show AWR Line', defval = false, inline = 'awr')
bool showWeeklyOpenAWR = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Use Weekly Open for AWR Calculation', defval = false, inline = 'awr', tooltip = 'Measure the AWR from the weekly open. This will make the AWR static throughout the week. AWR is usually measured taking this weeks High / Low. Since this weeks High / Low will change throughout the week, some might prefer to have a static range instead.')
bool showAWRLabels = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Show AWR Labels', defval = false, inline = 'awr1')
bool showAWR50 = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Show 50% AWR Lines and Labels', defval = false, inline = 'awr1')
string awrMetricDisplayMode = input.string(RANGE_METRIC, 'AWR Range Metrics', options = ['Off', RANGE_METRIC, CURRENCY_METRIC, 'Percent'], group = 'Average Weekly Range - AWR (intraday only)', inline = 'awr1')
int awrRange = input.int(group = 'Average Weekly Range - AWR (intraday only)', title = 'AWR length (weeks)', defval = 4, minval = 1, maxval = 52, step = 1, inline = 'awr2', tooltip = 'Defaults taken from MT4. This defines how many weeks back to take into consideration when calculating the AWR')
color awrColor = input.color(group = 'Average Weekly Range - AWR (intraday only)', title = 'AWR Color', defval = color.rgb(84, 123, 130), inline = 'awr3')
string awrStyleX = input.string(group = 'Average Weekly Range - AWR (intraday only)', defval = SOLID, title = 'AWR Line Style', options = [DOTTED, DASHED, SOLID], inline = 'awr3')
bool extendAWRLines = input.bool(group = 'Average Weekly Range - AWR (intraday only)', title = 'Extend AWR Lines in Both Directions', defval = false, inline = 'awr4')
string awrLineExtend = extendAWRLines ? extend.both : extend.none
string awrStyle = f_resolveLineStyle(awrStyleX)
bool calculateAWR = showAWR and isIntradayTimeframe

[weeklyAWRValue, weeklyAWRHighLevel, weeklyAWRLowLevel] =
 f_requestRangeLevels(
    calculateAWR,
    'W',
    awrRange,
    showWeeklyOpenAWR
)

float weeklyAWR50HighLevel = weeklyAWRHighLevel - weeklyAWRValue / 2
float weeklyAWR50LowLevel = weeklyAWRLowLevel + weeklyAWRValue / 2
bool showAWRMetrics = awrMetricDisplayMode != 'Off'

bool showAMR = input.bool(group = 'Average Monthly Range - AMR (Intraday Only)', title = 'Show AMR Line', defval = false, inline = 'amr')
bool showMonthlyOpenAMR = input.bool(group = 'Average Monthly Range - AMR (Intraday Only)', title = 'Use Monthly Open for AMR Calculation', defval = false, inline = 'amr', tooltip = 'Measure the AMR from the monthly open. This will make the AMR static throughout the month. AMR is usually measured taking this months High / Low. Since this months High / Low will change throughout the month, some might prefer to have a static range instead.')
bool showAMRLabels = input.bool(group = 'Average Monthly Range - AMR (Intraday Only)', title = 'Show AMR Labels', defval = false, inline = 'amr1')
bool showAMR50 = input.bool(group = 'Average Monthly Range - AMR (Intraday Only)', title = 'Show 50% AMR Lines and Labels', defval = false, inline = 'amr1')
string amrMetricDisplayMode = input.string(RANGE_METRIC, 'AMR Range Metrics', options = ['Off', RANGE_METRIC, CURRENCY_METRIC, 'Percent'], group = 'Average Monthly Range - AMR (Intraday Only)', inline = 'amr1')
int amrRange = input.int(group = 'Average Monthly Range - AMR (Intraday Only)', title = 'AMR length (months)', defval = 6, minval = 1, maxval = 12, step = 1, inline = 'amr2', tooltip = 'Defaults taken from MT4. This defines how many months back to take into consideration when calculating the AMR')
color amrColor = input.color(group = 'Average Monthly Range - AMR (Intraday Only)', title = 'AMR Color', defval = color.rgb(57, 90, 100), inline = 'amr3')
string amrStyleX = input.string(group = 'Average Monthly Range - AMR (Intraday Only)', defval = SOLID, title = 'AMR Line Style', options = [DOTTED, DASHED, SOLID], inline = 'amr3')
bool extendAMRLines = input.bool(group = 'Average Monthly Range - AMR (Intraday Only)', title = 'Extend AMR Lines in Both Directions', defval = false, inline = 'amr4')
string amrLineExtend = extendAMRLines ? extend.both : extend.none
string amrStyle = f_resolveLineStyle(amrStyleX)
bool calculateAMR = showAMR and isIntradayTimeframe and isMinuteChart and timeframe.multiplier >= 3

[monthlyAMRValue, monthlyAMRHighLevel, monthlyAMRLowLevel] =
 f_requestRangeLevels(
    calculateAMR,
    'M',
    amrRange,
    showMonthlyOpenAMR
)

float monthlyAMR50HighLevel = monthlyAMRHighLevel - monthlyAMRValue / 2
float monthlyAMR50LowLevel = monthlyAMRLowLevel + monthlyAMRValue / 2
bool showAMRMetrics = amrMetricDisplayMode != 'Off'

bool showPivotPoint = input.bool(group = 'Pivot Points (intraday only)', title = 'Show Pivot Point', defval = false)
bool showPivotLabels = input.bool(group = 'Pivot Points (intraday only)', title = 'Show Pivot/R/S Labels', defval = false)
color pivotColor = input.color(group = 'Pivot Points (intraday only)', title = 'Pivot Point Line Color', defval = color(#bdb76b), inline = 'pivotcolors')
color pivotLabelColor = input.color(group = 'Pivot Points (intraday only)', title = 'Pivot Point Label Color', defval = color(#bdb76b), inline = 'pivotcolors')
bool showLevelOnePivotPoints = input.bool(group = 'Pivot Points (intraday only)', title = 'Show Level 1 Resistance and Support Lines', defval = false, inline = 'pivotlevels')
bool showLevelTwoPivotPoints = input.bool(group = 'Pivot Points (intraday only)', title = 'Show Level 2 Resistance and Support Lines', defval = false, inline = 'pivotlevels')
bool showLevelThreePivotPoints = input.bool(group = 'Pivot Points (intraday only)', title = 'Show Level 3 Resistance and Support Lines', defval = false, inline = 'pivotlevels')
string resistanceAndSupportLineStyleX = input.string(group = 'Pivot Points (intraday only)', defval = DASHED, title = 'Resistance and Support Levels Line Style', options = [DOTTED, DASHED, SOLID], inline = 'pivotcolorsRS')
color pivotResistanceColor = input.color(group = 'Pivot Points (intraday only)', title = 'Resistance Line Color', defval = color(#fd5457), inline = 'pivotrscustom')
color pivotSupportColor = input.color(group = 'Pivot Points (intraday only)', title = 'Support Line Color', defval = color(#3ee145), inline = 'pivotrscustom')
bool extendPivots = input.bool(group = 'Pivot Points (intraday only)', title = 'Extend Lines in Both Directions', defval = false)
string resistanceAndSupportLineStyle = f_resolveLineStyle(resistanceAndSupportLineStyleX)
string pivotLineExtend = extendPivots ? extend.both : extend.none
bool drawPivotPointNow = isIntradayTimeframe and showPivotPoint
bool drawLevelOnePivotPointsNow = isIntradayTimeframe and showLevelOnePivotPoints
bool drawLevelTwoPivotPointsNow = isIntradayTimeframe and showLevelTwoPivotPoints
bool drawLevelThreePivotPointsNow = isIntradayTimeframe and showLevelThreePivotPoints

if barstate.islast
    if drawPivotPointNow
        pivotPointLine := f_upsertLine(pivotPointLine, dayStartTime, pivotPoint, dayEndTime, pivotPoint, pivotColor, resistanceAndSupportLineStyle, pivotLineExtend)
        pivotPointLabel := f_upsertOptionalLabel(pivotPointLabel, showPivotLabels, dayEndTime, pivotPoint, PIVOT_TAG, pivotLabelColor)
    else
        pivotPointLine := f_deleteLine(pivotPointLine)
        pivotPointLabel := f_deleteLabel(pivotPointLabel)

    if drawLevelOnePivotPointsNow
        pivotResistanceLevel1Line := f_upsertLine(pivotResistanceLevel1Line, dayStartTime, pivotResistanceLevel1, dayEndTime, pivotResistanceLevel1, pivotResistanceColor, resistanceAndSupportLineStyle, pivotLineExtend)
        pivotSupportLevel1Line := f_upsertLine(pivotSupportLevel1Line, dayStartTime, pivotSupportLevel1, dayEndTime, pivotSupportLevel1, pivotSupportColor, resistanceAndSupportLineStyle, pivotLineExtend)
        pivotResistanceLevel1Label := f_upsertOptionalLabel(pivotResistanceLevel1Label, showPivotLabels, dayEndTime, pivotResistanceLevel1, PIVOT_RESISTANCE_1_TAG, pivotResistanceColor)
        pivotSupportLevel1Label := f_upsertOptionalLabel(pivotSupportLevel1Label, showPivotLabels, dayEndTime, pivotSupportLevel1, PIVOT_SUPPORT_1_TAG, pivotSupportColor)
    else
        pivotResistanceLevel1Line := f_deleteLine(pivotResistanceLevel1Line)
        pivotSupportLevel1Line := f_deleteLine(pivotSupportLevel1Line)
        pivotResistanceLevel1Label := f_deleteLabel(pivotResistanceLevel1Label)
        pivotSupportLevel1Label := f_deleteLabel(pivotSupportLevel1Label)

    if drawLevelTwoPivotPointsNow
        pivotResistanceLevel2Line := f_upsertLine(pivotResistanceLevel2Line, dayStartTime, pivotResistanceLevel2, dayEndTime, pivotResistanceLevel2, pivotResistanceColor, resistanceAndSupportLineStyle, pivotLineExtend)
        pivotSupportLevel2Line := f_upsertLine(pivotSupportLevel2Line, dayStartTime, pivotSupportLevel2, dayEndTime, pivotSupportLevel2, pivotSupportColor, resistanceAndSupportLineStyle, pivotLineExtend)
        pivotResistanceLevel2Label := f_upsertOptionalLabel(pivotResistanceLevel2Label, showPivotLabels, dayEndTime, pivotResistanceLevel2, PIVOT_RESISTANCE_2_TAG, pivotResistanceColor)
        pivotSupportLevel2Label := f_upsertOptionalLabel(pivotSupportLevel2Label, showPivotLabels, dayEndTime, pivotSupportLevel2, PIVOT_SUPPORT_2_TAG, pivotSupportColor)
    else
        pivotResistanceLevel2Line := f_deleteLine(pivotResistanceLevel2Line)
        pivotSupportLevel2Line := f_deleteLine(pivotSupportLevel2Line)
        pivotResistanceLevel2Label := f_deleteLabel(pivotResistanceLevel2Label)
        pivotSupportLevel2Label := f_deleteLabel(pivotSupportLevel2Label)

    if drawLevelThreePivotPointsNow
        pivotResistanceLevel3Line := f_upsertLine(pivotResistanceLevel3Line, dayStartTime, pivotResistanceLevel3, dayEndTime, pivotResistanceLevel3, pivotResistanceColor, resistanceAndSupportLineStyle, pivotLineExtend)
        pivotSupportLevel3Line := f_upsertLine(pivotSupportLevel3Line, dayStartTime, pivotSupportLevel3, dayEndTime, pivotSupportLevel3, pivotSupportColor, resistanceAndSupportLineStyle, pivotLineExtend)
        pivotResistanceLevel3Label := f_upsertOptionalLabel(pivotResistanceLevel3Label, showPivotLabels, dayEndTime, pivotResistanceLevel3, PIVOT_RESISTANCE_3_TAG, pivotResistanceColor)
        pivotSupportLevel3Label := f_upsertOptionalLabel(pivotSupportLevel3Label, showPivotLabels, dayEndTime, pivotSupportLevel3, PIVOT_SUPPORT_3_TAG, pivotSupportColor)
    else
        pivotResistanceLevel3Line := f_deleteLine(pivotResistanceLevel3Line)
        pivotSupportLevel3Line := f_deleteLine(pivotSupportLevel3Line)
        pivotResistanceLevel3Label := f_deleteLabel(pivotResistanceLevel3Label)
        pivotSupportLevel3Label := f_deleteLabel(pivotSupportLevel3Label)

bool showMLevels = input.bool(group = 'M Levels (intraday only)', title = 'Show M Levels', defval = false, inline = 'mlevels')
bool showMLabels = input.bool(group = 'M Levels (intraday only)', title = 'Show M Levels Labels', defval = false, inline = 'mlevels')
color mLevelsColor = input.color(group = 'M Levels (intraday only)', title = 'M Levels Label Color', defval = color(#000000), inline = 'mLevelsColors1')
color mLevelsLabelColor = input.color(group = 'M Levels (intraday only)', title = 'M Levels Label', defval = color(#000000), inline = 'mLevelsColors1')
string mLevelsStyleX = input.string(group = 'M Levels (intraday only)', defval = DASHED, title = 'M Levels Line Style', options = [DOTTED, DASHED, SOLID], inline = 'mLevelsColors2')
bool extendMLevels = input.bool(group = 'M Levels (intraday only)', title = 'Extend Lines in Both Directions', defval = false)
string mLevelsStyle = f_resolveLineStyle(mLevelsStyleX)
string mLevelsLineExtend = extendMLevels ? extend.both : extend.none
bool drawMLevelsNow = isIntradayTimeframe and showMLevels

if barstate.islast
    if drawMLevelsNow
        mLevel0Line := f_upsertLine(mLevel0Line, dayStartTime, mLevel0, dayEndTime, mLevel0, mLevelsColor, mLevelsStyle, mLevelsLineExtend)
        mLevel1Line := f_upsertLine(mLevel1Line, dayStartTime, mLevel1, dayEndTime, mLevel1, mLevelsColor, mLevelsStyle, mLevelsLineExtend)
        mLevel2Line := f_upsertLine(mLevel2Line, dayStartTime, mLevel2, dayEndTime, mLevel2, mLevelsColor, mLevelsStyle, mLevelsLineExtend)
        mLevel3Line := f_upsertLine(mLevel3Line, dayStartTime, mLevel3, dayEndTime, mLevel3, mLevelsColor, mLevelsStyle, mLevelsLineExtend)
        mLevel4Line := f_upsertLine(mLevel4Line, dayStartTime, mLevel4, dayEndTime, mLevel4, mLevelsColor, mLevelsStyle, mLevelsLineExtend)
        mLevel5Line := f_upsertLine(mLevel5Line, dayStartTime, mLevel5, dayEndTime, mLevel5, mLevelsColor, mLevelsStyle, mLevelsLineExtend)
        mLevel0Label := f_upsertOptionalLabel(mLevel0Label, showMLabels, dayEndTime, mLevel0, M_LEVEL_0_TAG, mLevelsLabelColor)
        mLevel1Label := f_upsertOptionalLabel(mLevel1Label, showMLabels, dayEndTime, mLevel1, M_LEVEL_1_TAG, mLevelsLabelColor)
        mLevel2Label := f_upsertOptionalLabel(mLevel2Label, showMLabels, dayEndTime, mLevel2, M_LEVEL_2_TAG, mLevelsLabelColor)
        mLevel3Label := f_upsertOptionalLabel(mLevel3Label, showMLabels, dayEndTime, mLevel3, M_LEVEL_3_TAG, mLevelsLabelColor)
        mLevel4Label := f_upsertOptionalLabel(mLevel4Label, showMLabels, dayEndTime, mLevel4, M_LEVEL_4_TAG, mLevelsLabelColor)
        mLevel5Label := f_upsertOptionalLabel(mLevel5Label, showMLabels, dayEndTime, mLevel5, M_LEVEL_5_TAG, mLevelsLabelColor)
    else
        mLevel0Line := f_deleteLine(mLevel0Line)
        mLevel1Line := f_deleteLine(mLevel1Line)
        mLevel2Line := f_deleteLine(mLevel2Line)
        mLevel3Line := f_deleteLine(mLevel3Line)
        mLevel4Line := f_deleteLine(mLevel4Line)
        mLevel5Line := f_deleteLine(mLevel5Line)
        mLevel0Label := f_deleteLabel(mLevel0Label)
        mLevel1Label := f_deleteLabel(mLevel1Label)
        mLevel2Label := f_deleteLabel(mLevel2Label)
        mLevel3Label := f_deleteLabel(mLevel3Label)
        mLevel4Label := f_deleteLabel(mLevel4Label)
        mLevel5Label := f_deleteLabel(mLevel5Label)

bool showPsychologicalLevelsOnSupportedMinuteCharts = isMinuteChart and (timeframe.multiplier == 60 or timeframe.multiplier == 30 or timeframe.multiplier == 15 or timeframe.multiplier == 5 or timeframe.multiplier == 3 or timeframe.multiplier == 1)
bool showPsychologicalLevels = input.bool(group = 'Weekly Psychological Levels (Intraday Only)', defval = false, title = 'Show Psychological Levels', inline = 'psyconf') and showPsychologicalLevelsOnSupportedMinuteCharts
bool showPsychologicalLevelLabels = input.bool(group = 'Weekly Psychological Levels (Intraday Only)', defval = false, title = 'Show Psychological Level Labels', inline = 'psyconf', tooltip = 'The psychological High/Low will only show on these timeframes: 1h/30min/15min/5min/3min/1min. It is disabled on all others. This is because the calculation requires a candle to start at the correct time for Sydney/Tokyo but in other timeframes the data does not have values at the designated time for the Sydney/Tokyo sessions.') and showPsychologicalLevels
bool showAllHistoricalPsychologicalLevels = input.bool(group = 'Weekly Psychological Levels (Intraday Only)', defval = false, title = 'Show Historical Psychological Levels', inline = 'psyconf') and showPsychologicalLevels
string psychologicalAsiaSessionInputTime = input.session(group = 'Weekly Psychological Levels (Intraday Only)', defval = ASIA_SESSION_DEFAULT, title = 'Asia Session Time (ET):', inline = 'psyconf2')
color psychologicalLevelHighColor = input.color(group = 'Weekly Psychological Levels (Intraday Only)', title = 'Psychological High Color', defval = color(#ff9800), inline = 'psyconf1')
color psychologicalLevelLowColor = input.color(group = 'Weekly Psychological Levels (Intraday Only)', title = 'Psychological Low Color', defval = color(#ff9800), inline = 'psyconf1')

if not showAllHistoricalPsychologicalLevels
    f_deleteLineArray(historicalPsychologicalHighLinesArray)
    f_deleteLineArray(historicalPsychologicalLowLinesArray)
    activeHistoricalPsychologicalHighLine := na
    activeHistoricalPsychologicalLowLine := na

if showPsychologicalLevels
    string psychologicalAsiaSessionTime = psychologicalAsiaSessionInputTime + ALL_DAYS_SESSION_SUFFIX
    bool inPsychologicalAsiaSession = not na(time(timeframe.period, psychologicalAsiaSessionTime, NEW_YORK_TIMEZONE))
    int psychologicalBarDay = dayofweek(time, NEW_YORK_TIMEZONE)
    int psychologicalBarHour = hour(time, NEW_YORK_TIMEZONE)
    bool isSundayPsychologicalSessionBar = inPsychologicalAsiaSession and psychologicalBarDay == dayofweek.sunday and (not isCrypto or psychologicalBarHour >= 12)
    bool isMondayPsychologicalSessionBar = inPsychologicalAsiaSession and psychologicalBarDay == dayofweek.monday and psychologicalBarHour < 12
    bool inSundayMondayPsychologicalSession = isSundayPsychologicalSessionBar or isMondayPsychologicalSessionBar
    bool wasInSundayMondayPsychologicalSession = bar_index > 0 ? inSundayMondayPsychologicalSession[1] : false
    bool isNewSundayMondayPsychologicalSession = inSundayMondayPsychologicalSession and not wasInSundayMondayPsychologicalSession
    bool isConfirmedSundayMondayPsychologicalSession = not inSundayMondayPsychologicalSession and wasInSundayMondayPsychologicalSession

    if isNewSundayMondayPsychologicalSession
        if showAllHistoricalPsychologicalLevels and not na(activeHistoricalPsychologicalHighLine) and not na(activeHistoricalPsychologicalLowLine)
            line.set_x2(activeHistoricalPsychologicalHighLine, time)
            line.set_x2(activeHistoricalPsychologicalLowLine, time)

        weeklyPsychologicalSessionHigh := high
        weeklyPsychologicalSessionLow := low
        weeklyPsychologicalSessionStartTime := time
    else if inSundayMondayPsychologicalSession
        weeklyPsychologicalSessionHigh := na(weeklyPsychologicalSessionHigh) ? high : math.max(weeklyPsychologicalSessionHigh, high)
        weeklyPsychologicalSessionLow := na(weeklyPsychologicalSessionLow) ? low : math.min(weeklyPsychologicalSessionLow, low)
        weeklyPsychologicalSessionStartTime := na(weeklyPsychologicalSessionStartTime) ? time : weeklyPsychologicalSessionStartTime

    if isConfirmedSundayMondayPsychologicalSession
        confirmedPsychologicalSessionHigh := weeklyPsychologicalSessionHigh
        confirmedPsychologicalSessionLow := weeklyPsychologicalSessionLow

        if showAllHistoricalPsychologicalLevels and not na(weeklyPsychologicalSessionStartTime) and not na(confirmedPsychologicalSessionHigh) and not na(confirmedPsychologicalSessionLow)
            activeHistoricalPsychologicalHighLine := f_trackLine(
                 historicalPsychologicalHighLinesArray,
                 line.new(x1 = weeklyPsychologicalSessionStartTime, y1 = confirmedPsychologicalSessionHigh, x2 = time, y2 = confirmedPsychologicalSessionHigh, xloc = xloc.bar_time, extend = extend.none, color = psychologicalLevelHighColor, style = SOLID_LINE_STYLE, width = 1),
                 MAX_HISTORICAL_PSYCHOLOGICAL_WEEKS)
            activeHistoricalPsychologicalLowLine := f_trackLine(
                 historicalPsychologicalLowLinesArray,
                 line.new(x1 = weeklyPsychologicalSessionStartTime, y1 = confirmedPsychologicalSessionLow, x2 = time, y2 = confirmedPsychologicalSessionLow, xloc = xloc.bar_time, extend = extend.none, color = psychologicalLevelLowColor, style = SOLID_LINE_STYLE, width = 1),
                 MAX_HISTORICAL_PSYCHOLOGICAL_WEEKS)

    if showAllHistoricalPsychologicalLevels and not inSundayMondayPsychologicalSession
        if not na(activeHistoricalPsychologicalHighLine) and not na(confirmedPsychologicalSessionHigh)
            line.set_xy2(activeHistoricalPsychologicalHighLine, time, confirmedPsychologicalSessionHigh)

        if not na(activeHistoricalPsychologicalLowLine) and not na(confirmedPsychologicalSessionLow)
            line.set_xy2(activeHistoricalPsychologicalLowLine, time, confirmedPsychologicalSessionLow)

    psychologicalLevelHigh := weeklyPsychologicalSessionHigh
    psychologicalLevelLow := weeklyPsychologicalSessionLow
    psychologicalHighLabelText := PSYCHOLOGICAL_HIGH_LABEL
    psychologicalLowLabelText := PSYCHOLOGICAL_LOW_LABEL
    psychologicalSessionStartTime := weeklyPsychologicalSessionStartTime

bool canDrawPsychologicalLevels = showPsychologicalLevels and not na(psychologicalSessionStartTime) and not na(psychologicalLevelHigh) and not na(psychologicalLevelLow)

if barstate.islast
    if showPsychologicalLevelLabels and canDrawPsychologicalLevels
        psychologicalHighLabel := f_upsertLabel(psychologicalHighLabel, dayEndTime, psychologicalLevelHigh, psychologicalHighLabelText, psychologicalLevelHighColor)
        psychologicalLowLabel := f_upsertLabel(psychologicalLowLabel, dayEndTime, psychologicalLevelLow, psychologicalLowLabelText, psychologicalLevelLowColor)
    else
        psychologicalHighLabel := f_deleteLabel(psychologicalHighLabel)
        psychologicalLowLabel := f_deleteLabel(psychologicalLowLabel)

if barstate.islast
    if showDailyOpenLine and isIntradayTimeframe and not showHistoricalDailyOpenLines
        dailyOpenLine := f_upsertLine(dailyOpenLine, dayStartTime, dailyOpenPrice, dayEndTime, dailyOpenPrice, dailyOpenColor, dailyOpenLineStyle, dailyOpenLineExtend)
    else
        dailyOpenLine := f_deleteLine(dailyOpenLine)

    if showDailyOpenLine and isIntradayTimeframe and showDailyOpenLabel
        dailyOpenLabel := f_upsertLabel(dailyOpenLabel, dayEndTime, dailyOpenPrice, DAILY_OPEN_LABEL, dailyOpenColor)
    else
        dailyOpenLabel := f_deleteLabel(dailyOpenLabel)

    if isIntradayTimeframe and showPreviousDayHighLow
        previousDayHighLine := f_upsertLine(previousDayHighLine, dayStartTime, previousDayHigh, dayEndTime, previousDayHigh, previousDayHighLowColor, previousDayHighLowStyle, previousDayLineExtend)
        previousDayLowLine := f_upsertLine(previousDayLowLine, dayStartTime, previousDayLow, dayEndTime, previousDayLow, previousDayHighLowColor, previousDayHighLowStyle, previousDayLineExtend)
    else
        previousDayHighLine := f_deleteLine(previousDayHighLine)
        previousDayLowLine := f_deleteLine(previousDayLowLine)

    if isIntradayTimeframe and showPreviousDayHighLow and showPreviousDayHighLowLabels
        previousDayHighLabel := f_upsertLabel(previousDayHighLabel, dayEndTime, previousDayHigh, PDH_LABEL, previousDayHighLowColor)
        previousDayLowLabel := f_upsertLabel(previousDayLowLabel, dayEndTime, previousDayLow, PDL_LABEL, previousDayHighLowColor)
    else
        previousDayHighLabel := f_deleteLabel(previousDayHighLabel)
        previousDayLowLabel := f_deleteLabel(previousDayLowLabel)

    if isIntradayOrDailyTimeframe and showPreviousWeekHighLow
        previousWeekHighLine := f_upsertLine(previousWeekHighLine, dayStartTime, previousWeekHigh, dayEndTime, previousWeekHigh, previousWeekHighLowColor, previousWeekHighLowStyle, previousWeekLineExtend)
        previousWeekLowLine := f_upsertLine(previousWeekLowLine, dayStartTime, previousWeekLow, dayEndTime, previousWeekLow, previousWeekHighLowColor, previousWeekHighLowStyle, previousWeekLineExtend)
    else
        previousWeekHighLine := f_deleteLine(previousWeekHighLine)
        previousWeekLowLine := f_deleteLine(previousWeekLowLine)

    if isIntradayOrDailyTimeframe and showPreviousWeekHighLow and showPreviousDayHighLowLabels
        previousWeekHighLabel := f_upsertLabel(previousWeekHighLabel, dayEndTime, previousWeekHigh, PWH_LABEL, previousWeekHighLowColor)
        previousWeekLowLabel := f_upsertLabel(previousWeekLowLabel, dayEndTime, previousWeekLow, PWL_LABEL, previousWeekHighLowColor)
    else
        previousWeekHighLabel := f_deleteLabel(previousWeekHighLabel)
        previousWeekLowLabel := f_deleteLabel(previousWeekLowLabel)

    if showADR and isIntradayTimeframe
        adrHighLine := f_upsertLine(adrHighLine, dayStartTime, dailyADRHighLevel, dayEndTime, dailyADRHighLevel, activeADRColor, adrStyle, adrLineExtend)
        adrLowLine := f_upsertLine(adrLowLine, dayStartTime, dailyADRLowLevel, dayEndTime, dailyADRLowLevel, activeADRColor, adrStyle, adrLineExtend)
        if not na(adrHighLine)
            line.set_width(adrHighLine, activeADRLineWidth)
        if not na(adrLowLine)
            line.set_width(adrLowLine, activeADRLineWidth)
    else
        adrHighLine := f_deleteLine(adrHighLine)
        adrLowLine := f_deleteLine(adrLowLine)

    if showADR and showADR50 and isIntradayTimeframe
        adr50HighLine := f_upsertLine(adr50HighLine, dayStartTime, dailyADR50HighLevel, dayEndTime, dailyADR50HighLevel, adrColor, adrStyle, adrLineExtend)
        adr50LowLine := f_upsertLine(adr50LowLine, dayStartTime, dailyADR50LowLevel, dayEndTime, dailyADR50LowLevel, adrColor, adrStyle, adrLineExtend)
    else
        adr50HighLine := f_deleteLine(adr50HighLine)
        adr50LowLine := f_deleteLine(adr50LowLine)

    if showADR and isIntradayTimeframe and showADRLabels
        adrHighLabel := f_upsertLabel(adrHighLabel, dayEndTime, dailyADRHighLevel, ADR_HIGH_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), activeADRColor)
        adrLowLabel := f_upsertLabel(adrLowLabel, dayEndTime, dailyADRLowLevel, ADR_LOW_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), activeADRColor)
    else
        adrHighLabel := f_deleteLabel(adrHighLabel)
        adrLowLabel := f_deleteLabel(adrLowLabel)

    if showADR and showADR50 and isIntradayTimeframe and showADRLabels
        adr50HighLabel := f_upsertLabel(adr50HighLabel, dayEndTime, dailyADR50HighLevel, ADR_50_HIGH_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), activeADRColor)
        adr50LowLabel := f_upsertLabel(adr50LowLabel, dayEndTime, dailyADR50LowLevel, ADR_50_LOW_LABEL + (showDailyOpenADR ? DAILY_OPEN_SUFFIX : ''), activeADRColor)
    else
        adr50HighLabel := f_deleteLabel(adr50HighLabel)
        adr50LowLabel := f_deleteLabel(adr50LowLabel)

    if showADR and isIntradayTimeframe and showADRLabels and showADRMetrics
        adrRangeOffset = showADR50 ? math.max(syminfo.mintick * 20, dailyADRValue * 0.02) : 0.0
        adrMid = (dailyADRHighLevel + dailyADRLowLevel) / 2 + adrRangeOffset
        adrText = ADR_RANGE_PREFIX + f_formatRangeMetric(dailyADRValue, adrMetricDisplayMode) + '\n' + ADR_3X_PREFIX + f_formatRangeMetric(dailyADRValue * 3, adrMetricDisplayMode)
        adrRangeLabel := f_upsertLabel(adrRangeLabel, dayEndTime, adrMid, adrText, activeADRColor)
    else
        adrRangeLabel := f_deleteLabel(adrRangeLabel)

    if showADR and showADR50 and isIntradayTimeframe and showADRLabels and showADRMetrics
        adrRangeOffset50 = math.max(syminfo.mintick * 10, dailyADRValue * 0.02)
        adrMid50 = (dailyADR50HighLevel + dailyADR50LowLevel) / 2 - adrRangeOffset50
        adrText50 = ADR_50_RANGE_PREFIX + f_formatRangeMetric(dailyADRValue / 2, adrMetricDisplayMode)
        adr50RangeLabel := f_upsertLabel(adr50RangeLabel, dayEndTime, adrMid50, adrText50, activeADRColor)
    else
        adr50RangeLabel := f_deleteLabel(adr50RangeLabel)

    if showAWR and isIntradayTimeframe
        awrHighLine := f_upsertLine(awrHighLine, dayStartTime, weeklyAWRHighLevel, dayEndTime, weeklyAWRHighLevel, awrColor, awrStyle, awrLineExtend)
        awrLowLine := f_upsertLine(awrLowLine, dayStartTime, weeklyAWRLowLevel, dayEndTime, weeklyAWRLowLevel, awrColor, awrStyle, awrLineExtend)
    else
        awrHighLine := f_deleteLine(awrHighLine)
        awrLowLine := f_deleteLine(awrLowLine)

    if showAWR and showAWR50 and isIntradayTimeframe
        awr50HighLine := f_upsertLine(awr50HighLine, dayStartTime, weeklyAWR50HighLevel, dayEndTime, weeklyAWR50HighLevel, awrColor, awrStyle, awrLineExtend)
        awr50LowLine := f_upsertLine(awr50LowLine, dayStartTime, weeklyAWR50LowLevel, dayEndTime, weeklyAWR50LowLevel, awrColor, awrStyle, awrLineExtend)
    else
        awr50HighLine := f_deleteLine(awr50HighLine)
        awr50LowLine := f_deleteLine(awr50LowLine)

    if showAWR and isIntradayTimeframe and showAWRLabels
        awrHighLabel := f_upsertLabel(awrHighLabel, dayEndTime, weeklyAWRHighLevel, AWR_HIGH_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
        awrLowLabel := f_upsertLabel(awrLowLabel, dayEndTime, weeklyAWRLowLevel, AWR_LOW_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
    else
        awrHighLabel := f_deleteLabel(awrHighLabel)
        awrLowLabel := f_deleteLabel(awrLowLabel)

    if showAWR and showAWR50 and isIntradayTimeframe and showAWRLabels
        awr50HighLabel := f_upsertLabel(awr50HighLabel, dayEndTime, weeklyAWR50HighLevel, AWR_50_HIGH_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
        awrLow50Label := f_upsertLabel(awrLow50Label, dayEndTime, weeklyAWR50LowLevel, AWR_50_LOW_LABEL + (showWeeklyOpenAWR ? WEEKLY_OPEN_SUFFIX : ''), awrColor)
    else
        awr50HighLabel := f_deleteLabel(awr50HighLabel)
        awrLow50Label := f_deleteLabel(awrLow50Label)

    if showAWR and isIntradayTimeframe and showAWRLabels and showAWRMetrics
        awrRangeOffset = showAWR50 ? math.max(syminfo.mintick * 20, weeklyAWRValue * 0.02) : 0.0
        awrMid = (weeklyAWRHighLevel + weeklyAWRLowLevel) / 2 + awrRangeOffset
        awrText = AWR_RANGE_PREFIX + f_formatRangeMetric(weeklyAWRValue, awrMetricDisplayMode) + '\n' + AWR_3X_PREFIX + f_formatRangeMetric(weeklyAWRValue * 3, awrMetricDisplayMode)
        awrRangeLabel := f_upsertLabel(awrRangeLabel, dayEndTime, awrMid, awrText, awrColor)
    else
        awrRangeLabel := f_deleteLabel(awrRangeLabel)

    if showAWR and showAWR50 and isIntradayTimeframe and showAWRLabels and showAWRMetrics
        awrRangeOffset50 = math.max(syminfo.mintick * 10, weeklyAWRValue * 0.02)
        awrMid50 = (weeklyAWR50HighLevel + weeklyAWR50LowLevel) / 2 - awrRangeOffset50
        awrText50 = AWR_50_RANGE_PREFIX + f_formatRangeMetric(weeklyAWRValue / 2, awrMetricDisplayMode)
        awr50RangeLabel := f_upsertLabel(awr50RangeLabel, dayEndTime, awrMid50, awrText50, awrColor)
    else
        awr50RangeLabel := f_deleteLabel(awr50RangeLabel)

    if showAMR and isIntradayTimeframe and isMinuteChart and timeframe.multiplier >= 3
        amrHighLine := f_upsertLine(amrHighLine, dayStartTime, monthlyAMRHighLevel, dayEndTime, monthlyAMRHighLevel, amrColor, amrStyle, amrLineExtend)
        amrLowLine := f_upsertLine(amrLowLine, dayStartTime, monthlyAMRLowLevel, dayEndTime, monthlyAMRLowLevel, amrColor, amrStyle, amrLineExtend)
    else
        amrHighLine := f_deleteLine(amrHighLine)
        amrLowLine := f_deleteLine(amrLowLine)

    if showAMR and showAMR50 and isIntradayTimeframe and isMinuteChart and timeframe.multiplier >= 3
        amr50HighLine := f_upsertLine(amr50HighLine, dayStartTime, monthlyAMR50HighLevel, dayEndTime, monthlyAMR50HighLevel, amrColor, amrStyle, amrLineExtend)
        amr50LowLine := f_upsertLine(amr50LowLine, dayStartTime, monthlyAMR50LowLevel, dayEndTime, monthlyAMR50LowLevel, amrColor, amrStyle, amrLineExtend)
    else
        amr50HighLine := f_deleteLine(amr50HighLine)
        amr50LowLine := f_deleteLine(amr50LowLine)

    if showAMR and isIntradayTimeframe and showAMRLabels and isMinuteChart and timeframe.multiplier >= 3
        amrHighLabel := f_upsertLabel(amrHighLabel, dayEndTime, monthlyAMRHighLevel, AMR_HIGH_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
        amrLowLabel := f_upsertLabel(amrLowLabel, dayEndTime, monthlyAMRLowLevel, AMR_LOW_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
    else
        amrHighLabel := f_deleteLabel(amrHighLabel)
        amrLowLabel := f_deleteLabel(amrLowLabel)

    if showAMR and showAMR50 and isIntradayTimeframe and showAMRLabels and isMinuteChart and timeframe.multiplier >= 3
        amr50HighLabel := f_upsertLabel(amr50HighLabel, dayEndTime, monthlyAMR50HighLevel, AMR_50_HIGH_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
        amr50LowLabel := f_upsertLabel(amr50LowLabel, dayEndTime, monthlyAMR50LowLevel, AMR_50_LOW_LABEL + (showMonthlyOpenAMR ? MONTHLY_OPEN_SUFFIX : ''), amrColor)
    else
        amr50HighLabel := f_deleteLabel(amr50HighLabel)
        amr50LowLabel := f_deleteLabel(amr50LowLabel)

    if showAMR and isIntradayTimeframe and showAMRLabels and showAMRMetrics and isMinuteChart and timeframe.multiplier >= 3
        amrRangeOffset = showAMR50 ? math.max(syminfo.mintick * 20, monthlyAMRValue * 0.02) : 0.0
        amrMid = (monthlyAMRHighLevel + monthlyAMRLowLevel) / 2 + amrRangeOffset
        amrText = AMR_RANGE_PREFIX + f_formatRangeMetric(monthlyAMRValue, amrMetricDisplayMode) + '\n' + AMR_3X_PREFIX + f_formatRangeMetric(monthlyAMRValue * 3, amrMetricDisplayMode)
        amrRangeLabel := f_upsertLabel(amrRangeLabel, dayEndTime, amrMid, amrText, amrColor)
    else
        amrRangeLabel := f_deleteLabel(amrRangeLabel)

    if showAMR and showAMR50 and isIntradayTimeframe and showAMRLabels and showAMRMetrics and isMinuteChart and timeframe.multiplier >= 3
        amrRangeOffset50 = math.max(syminfo.mintick * 10, monthlyAMRValue * 0.02)
        amrMid50 = (monthlyAMR50HighLevel + monthlyAMR50LowLevel) / 2 - amrRangeOffset50
        amrText50 = AMR_50_RANGE_PREFIX + f_formatRangeMetric(monthlyAMRValue / 2, amrMetricDisplayMode)
        amr50RangeLabel := f_upsertLabel(amr50RangeLabel, dayEndTime, amrMid50, amrText50, amrColor)
    else
        amr50RangeLabel := f_deleteLabel(amr50RangeLabel)

if barstate.islast
    if canDrawPsychologicalLevels
        psychologicalHighLine := f_upsertLine(psychologicalHighLine, psychologicalSessionStartTime, psychologicalLevelHigh, dayEndTime, psychologicalLevelHigh, psychologicalLevelHighColor, SOLID_LINE_STYLE, extend.none)
        psychologicalLowLine := f_upsertLine(psychologicalLowLine, psychologicalSessionStartTime, psychologicalLevelLow, dayEndTime, psychologicalLevelLow, psychologicalLevelLowColor, SOLID_LINE_STYLE, extend.none)
    else
        psychologicalHighLine := f_deleteLine(psychologicalHighLine)
        psychologicalLowLine := f_deleteLine(psychologicalLowLine)
